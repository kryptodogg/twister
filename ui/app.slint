// ui/app.slint — Twister v0.5 — SDR/DSP/ML Core UI
//
// Aesthetic: industrial signal-intelligence terminal.
// Dark chromatic background, phosphor-green / electric-cyan accents,
// monospaced data everywhere, zero decorative chrome.
//
// Refresh: driven by slint::Timer at 16 ms (≈60 Hz) in main.rs.
// For true display vsync set env SLINT_BACKEND=winit (Windows default) or
// SLINT_BACKEND=winit-femtovg for GPU compositing.

import { CopilotPanel, ChatMessage } from "copilot_panel.slint";
import { Slider } from "std-widgets.slint";
import { JoyconWidget, JoyconBackend } from "widgets/joycon_imu.slint";
import { PlutoWidget, PlutoBackend } from "widgets/pluto_tuner.slint";
import { RtlSdrWidget, RtlSdrBackend } from "widgets/rtlsdr_tuner.slint";

export { JoyconWidget, JoyconBackend, PlutoWidget, PlutoBackend, RtlSdrWidget, RtlSdrBackend }

// ─── Colour palette ───────────────────────────────────────────────────────────
global Pal {
    // Backgrounds
    out property <color> bg:      #07080f;
    out property <color> surface: #0d0e1c;
    out property <color> card:    #111322;
    out property <color> border:  #1c2040;

    // Text
    out property <color> hi:      #dce4ff;
    out property <color> lo:      #424870;
    out property <color> mid:     #7a85b0;

    // Accents
    out property <color> cyan:    #00d4ff;   // primary / running
    out property <color> green:   #00e676;   // OK / ANC calibrated
    out property <color> amber:   #ffaa00;   // warning / noise mode
    out property <color> red:     #ff4040;   // danger / clipping
    out property <color> purple:  #c688ff;   // PDM / Mamba
    out property <color> orange:  #ff7043;   // sweep
}

// ─── Primitive components ─────────────────────────────────────────────────────

// Flat dark card
component Card inherits Rectangle {
    background: Pal.card;
    border-color: Pal.border;
    border-width: 1px;
    border-radius: 6px;
}

// Uppercase micro-label
component Lbl inherits Text {
    color: Pal.lo;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.2px;
}

// Monospaced readout value
component Mon inherits Text {
    color: Pal.hi;
    font-size: 12px;
    font-weight: 700;
    font-family: "Consolas";
}

// Horizontal fill bar (left to right)
component HBar inherits Rectangle {
    in property <float> frac:    0.0;
    in property <color> bar-color:     Pal.cyan;
    in property <float> warn_at: 0.90;
    height: 6px;
    border-radius: 3px;
    background: Pal.border;
    Rectangle {
        x: 0px;
        y: 0px;
        height: parent.height;
        width: max(parent.width * clamp(frac, 0.0, 1.0), 0px);
        border-radius: 3px;
        background: frac >= warn_at ? Pal.red : bar-color;
        animate width { duration: 40ms; }
    }
}

// VBar — vertical fill bar (bottom to top).
// Used by the Mamba latent-32 placeholder display in the right panel.
// The spectrum uses SVG Path instead (see spectrum-path-* properties).
component VBar inherits Rectangle {
    in property <float> frac:      0.0;
    in property <color> bar-color: Pal.cyan;
    background: Pal.border.with-alpha(0.18);
    Rectangle {
        property <length> fill-h: max(parent.height * clamp(frac, 0.0, 1.0), 1px);
        x: 0px;
        y: parent.height - fill-h;
        width: parent.width;
        height: fill-h;
        background: bar-color;
    }
}

// Mode / option pill button
component Chip inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    in property <color> accent: Pal.cyan;
    callback clicked;
    height: 26px;
    border-radius: 5px;
    background: active ? accent.with-alpha(0.16) : Pal.border.with-alpha(0.6);
    border-width: active ? 1.5px : 1px;
    border-color: active ? accent : Pal.border;
    animate background { duration: 80ms; }
    animate border-color { duration: 80ms; }
    Text {
        text: label;
        color: active ? accent : Pal.lo;
        font-size: 10px;
        font-weight: active ? 800 : 500;
        letter-spacing: 0.5px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

// Toggle switch
component Toggle inherits Rectangle {
    in property <bool> on;
    in property <color> accent: Pal.cyan;
    callback toggled;
    width: 36px;
    height: 20px;
    border-radius: 10px;
    background: on ? accent.with-alpha(0.9) : Pal.border;
    animate background { duration: 120ms; }
    Rectangle {
        width: 16px;
        height: 16px;
        border-radius: 8px;
        x: on ? parent.width - 18px : 2px;
        y: 2px;
        background: on ? white : Pal.mid;
        animate x { duration: 120ms; }
    }

    TouchArea {
        clicked => {
            root.toggled();
        }
    }
}

// ─── Memo Card (forensic event log entry) ─────────────────────────────────────
component MemoCard inherits Card {
    in property <string> timestamp;    // ISO 8601 with microseconds
    in property <string> tag;           // NOTE, EVIDENCE, MANUAL-REC, ANALYSIS
    in property <string> content;       // Main text (80 chars max)
    in property <bool> show-delete:    false;
    callback delete-clicked;
    property <color> tag-color:
        tag == "EVIDENCE" ? Pal.cyan : tag == "MANUAL-REC" ? Pal.green : tag == "ANALYSIS" ? Pal.amber : Pal.purple;  // NOTE

    height: 66px;
    VerticalLayout {
        spacing: 2px;
        padding: 8px;
        HorizontalLayout {
            Mon {
                text: "[" + timestamp + " UTC]";
                color: Pal.lo;
                font-size: 9px;
                font-weight: 400;
            }
        }

        HorizontalLayout {
            spacing: 6px;
            Mon {
                text: "[" + tag + "]";
                color: tag-color;
                font-size: 11px;
                font-weight: 700;
            }

            Mon {
                text: content;
                color: Pal.hi;
                font-size: 11px;
                font-weight: 400;
                horizontal-stretch: 1;
            }

            if show-delete: Rectangle {
                width: 20px;
                Text {
                    text: "✕";
                    color: Pal.red;
                    font-size: 14px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => {
                        delete-clicked();
                    }
                }
            }
        }
    }
}

// ─── Log Entry (console line) ────────────────────────────────────────────────
component LogEntry inherits Rectangle {
    in property <string> timestamp;
    in property <string> level;
    in property <string> module;
    in property <string> message;
    height: 16px;
    HorizontalLayout {
        spacing: 8px;
        padding-left: 4px;
        Text {
            text: "[" + timestamp + "]";
            color: Pal.lo;
            font-size: 10px;
            font-family: "Consolas";
            vertical-alignment: center;
        }

        Text {
            text: "[" + level + "]";
            color: level == "ERROR" ? Pal.red : level == "WARN" ? Pal.amber : level == "INFO" ? Pal.green : Pal.mid;
            font-size: 10px;
            font-weight: 800;
            font-family: "Consolas";
            vertical-alignment: center;
            width: 50px;
        }

        Text {
            text: "[" + module + "]";
            color: Pal.cyan;
            font-size: 10px;
            font-family: "Consolas";
            vertical-alignment: center;
            width: 80px;
        }

        Text {
            text: message;
            color: Pal.hi;
            font-size: 10px;
            font-family: "Consolas";
            horizontal-stretch: 1;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

// ─── Main window ──────────────────────────────────────────────────────────────
export component AppWindow inherits Window {
    title: "Twister v0.5  ·  SDR/DSP/ML Core";
    background: Pal.bg;
    min-width: 1280px;
    min-height: 780px;

    // ── Inbound properties (set by Rust 16 ms timer) ──────────────────────────
    in property <float> detected-freq:       440.0;
    in property <bool> is-running:          false;
    in property <int> current-mode:        0;
    in property <bool> auto-tune-active:    false;
    in property <float> master-gain:         0.5;
    in property <bool> pdm-active:          false;
    in property <float> pdm-clock-mhz:       12.288;
    in property <int> oversample-ratio:    64;
    in property <float> pdm-snr-db:          0.0;
    in property <int> waveshape-mode:      0;
    in property <float> waveshape-drive:     0.5;
    in property <int> input-device-count:  1;
    in property <float> beam-azimuth-deg:    0.0;
    in property <float> beam-confidence:     0.0;
    in property <float> beam-focus-deg:      45.0;
    in property <string> waterfall-max-freq:  "96.0 kHz";
    in property <string> waterfall-mid-freq:  "9.8 kHz";
    in property <float> agc-gain-db:         0.0;
    in property <float> agc-peak-dbfs:      -60.0;
    in property <float> output-peak-db:     -60.0;
    // 108 dB SNL: dynamic range = AGC gain applied + ADC headroom (fixed 48 dB) + noise floor offset
    // Displayed as a read-only figure in the footer.
    in property <float> snl-db:             108.0;

    // Visualization — paths built by Rust each frame
    // spectrum-path: SVG commands string for the filled spectrum waveform.
    //   Coordinate system: x = 0..1000 (maps to full width), y = 0..100 (top=loud, bottom=quiet).
    //   Three filled sub-paths — green (low), cyan (mid), red (high) — each closed to baseline.
    //   Built in main.rs using log-spaced bin positions.
    in-out property <string> spectrum-path-green:  "M 0 100 L 1000 100 Z";
    in-out property <string> spectrum-path-cyan:   "M 0 100 L 1000 100 Z";
    in-out property <string> spectrum-path-red:    "M 0 100 L 1000 100 Z";
    // Waterfall rendered as a smooth Image (bilinear-interpolated by FemtoVG — no pixelation).
    in-out property <image> waterfall-image;

    // v0.4 additions
    in-out property <string> anc-status:    "ANC uncalibrated";
    in-out property <float> dispatch-ms:   0.0;
    in-out property <int> frame-count:   0;
    in-out property <string> waveform-path: "M 0 50 L 100 50";

    // Mamba training
    in-out property <float> mamba-anomaly: 0.0;
    in-out property <int> replay-buf-len:  0;
    in-out property <[float]> loss-history: [];
    in property <[float]> latent-embedding: [];  // 32-dim latent vector from Mamba
    in-out property <bool> mamba-emergency-off: false;
    in-out property <float> smart-anc-blend:   0.3;

    // ── Neural Waveshaper (latent projection) ──────────────────────────────────
    in-out property <float> waveshaper-anomaly: 0.0;      // Reconstruction MSE score
    in-out property <float> waveshaper-confidence: 0.0;   // Projection confidence
    in-out property <float> waveshaper-drive: 0.0;        // Distortion amplitude [0, 1]
    in-out property <float> waveshaper-foldback: 0.0;     // Alias spread [0, 1]
    in-out property <float> waveshaper-asymmetry: 0.5;    // Harmonic bias [0, 1] (mapped from [-1, 1])
    in-out property <string> waveshaper-status: "🟢 MONITORING";

    // SDR tab
    in property <float> sdr-center-mhz:       100.0;
    in property <float> sdr-gain-db:          20.0;
    in property <float> sdr-peak-dbfs:       -60.0;
    in property <float> sdr-peak-offset-khz:  0.0;
    in property <bool> sdr-active:           false;

    // DC Offset Forensic Monitoring
    in property <float> sdr-dc-bias:          0.0;    // RF center frequency energy (unfiltered evidence)
    in property <float> audio-dc-bias:        0.0;    // Audio DC offset (tazer pressure component)
    in property <bool> dc-warning-active:    false;   // Alert when DC bias exceeds threshold

    // ── Twister: musical auto-tuner ────────────────────────────────────────────
    in property <string> note-name:   "---";   // e.g. "A4", "C#5"
    in property <float> note-cents:  0.0;     // cents offset from raw detection

    in property <string> gate-status: "IDLE";
    in property <string> last-gate-reason: "";
    in property <int> training-pairs-dropped: 0;
    in property <int> gate-rejections-low-anomaly: 0;
    in property <int> gate-rejections-low-confidence: 0;

    // ── Tab navigation ────────────────────────────────────────────────────────
    in-out property <int> active-tab: 0;  // 0 = TWISTER, 1 = TRAINING, 2 = MEMOS, 3 = ANALYSIS, 4 = CONSOLE
    in-out property <[string]> log-timestamps: [];
    in-out property <[string]> log-levels: [];
    in-out property <[string]> log-modules: [];
    in-out property <[string]> log-messages: [];

    // ── Training tab properties ───────────────────────────────────────────────
    in property <float> rtl-freq-mhz:             100.0;
    in property <bool> rtl-connected:            false;
    in property <bool> rtl-scanning:             false;
    in property <int> training-pairs:           0;
    in property <float> training-loss:            0.0;
    in property <int> training-epoch:           0;
    in property <bool> training-active:          false;
    in-out property <string> rtl-spectrum-path:   "M 0 100 L 1000 100 Z";
    in-out property <string> tx-spectrum-path:    "M 0 100 L 1000 100 Z";
    in-out property <string> reconstruction-path: "M 0 100 L 1000 100";

    // ── Manual Recording (REC button) ──────────────────────────────────────────
    in-out property <bool> manual-rec-active:    false;
    in-out property <string> manual-rec-notes:   "";
    in property <string> manual-rec-status:      "IDLE";  // IDLE, RECORDING, SAVING
    in property <int> manual-rec-countdown-ms:   0;       // Remaining time in 30s capture

    // ── Memos/Notes Tab ────────────────────────────────────────────────────────
    in-out property <[string]> memo-timestamps: [];       // ISO 8601 timestamps
    in-out property <[string]> memo-tags:       [];       // NOTE, EVIDENCE, MANUAL-REC, ANALYSIS
    in-out property <[string]> memo-contents:   [];       // User text (max 80 chars each)
    in-out property <string> memo-input-tag:    "NOTE";   // Current input tag selector
    in-out property <string> memo-input-text:   "";       // Current input text
    in-out property <string> memo-search-text:  "";       // Search filter text
    in-out property <string> memo-search-tag:   "ALL";    // Search filter tag (ALL, NOTE, EVIDENCE, MANUAL-REC, ANALYSIS)

    // ── Analysis Tab properties ────────────────────────────────────────────────
    // Temporal Scatter Plot
    in property <[float]> analysis-events-time:      [];   // timestamp_weeks for each event
    in property <[float]> analysis-events-intensity: [];   // intensity [0.0, 1.0] for each event
    in property <[int]> analysis-events-cluster:    [];    // cluster_type for coloring
    in property <[float]> analysis-events-frequency: [];   // frequency_hz for each event

    // ── Parameter Control Layer (Track B Addendum BB) ──────────────────────────
    // Audio Device Selection
    in property <int> audio-device-idx:              0;
    in property <float> audio-gain-db:              0.0;
    in property <[string]> audio-device-names:      [];

    // Camera Configuration
    in property <int> camera-resolution:             1;    // 0=480p, 1=720p, 2=1080p
    in property <float> camera-fps:                 30.0;
    in property <bool> camera-active:              false;

    // Frequency Selection
    in property <int> freq-band-index:               4;    // 0=VLF, 1=LF, 2=MF, 3=HF, 4=VHF, 5=UHF, 6=Manual
    in property <float> freq-manual-mhz:           100.0;
    in property <float> freq-actual-mhz:           150.0;

    // Joy-Con Gesture Control
    in property <bool> joycon-connected:           false;
    in property <bool> joycon-active:              false;
    in property <float> joycon-gyro-roll:            0.0;  // degrees
    in property <float> joycon-gyro-pitch:           0.0;  // degrees
    in property <float> joycon-gyro-yaw:             0.0;  // degrees
    in property <float> joycon-accel-x:              0.0;  // G
    in property <float> joycon-accel-y:              0.0;  // G
    in property <float> joycon-accel-z:              0.0;  // G
    in property <float> joycon-stick-left-x:         0.0;  // [-1, 1]
    in property <float> joycon-stick-left-y:         0.0;  // [-1, 1]
    in property <float> joycon-stick-right-x:        0.0;  // [-1, 1]
    in property <float> joycon-stick-right-y:        0.0;  // [-1, 1]
    in property <float> joycon-trigger-l:            0.0;  // [0, 1]
    in property <float> joycon-trigger-r:            0.0;  // [0, 1]
    in property <bool> joycon-button-a:            false;
    in property <bool> joycon-button-b:            false;
    in property <bool> joycon-button-x:            false;
    in property <bool> joycon-button-y:            false;

    // Parameter Persistence
    callback save-parameters();
    callback load-parameters();
    callback reset-parameters();

    // Audio Device Control
    callback audio-device-prev();
    callback audio-device-next();
    callback set-audio-gain(float);

    // Camera Control
    callback set-camera-resolution(int);
    callback toggle-camera();

    // Frequency Control
    callback set-freq-band(int);
    callback set-freq-manual(float);

    // Joy-Con Control
    callback toggle-joycon();

    // Pattern Library Heatmap
    in property <[string]> analysis-signatures-names:   [];  // Attack signature names
    in property <[int]> analysis-signatures-counts:    [];   // Occurrence counts
    in property <[[float]]> analysis-signatures-features: []; // 2D array [sig_idx][feat_idx] importance

    // Clustering Dendrogram
    in property <[string]> analysis-clusters-names:   [];   // Cluster names
    in property <[int]> analysis-clusters-sizes:      [];   // Cluster sizes
    in property <[float]> analysis-clusters-coherence: [];  // Coherence [0.0, 1.0]

    // Correlation Graph
    in property <[int]> analysis-correlations-a:   [];      // event_a indices
    in property <[int]> analysis-correlations-b:   [];      // event_b indices
    in property <[int]> analysis-correlations-type: [];     // correlation_type
    in property <[float]> analysis-correlations-strength: []; // strength [0.0, 1.0]

    // ── Callbacks ─────────────────────────────────────────────────────────────
    callback set-mode(int);
    callback set-gain(float);
    callback set-freq-override(float);
    callback toggle-auto-tune();
    callback toggle-running();
    callback toggle-pdm();
    callback set-waveshape(int);
    callback set-waveshape-drive(float);
    callback set-beam-focus(float);
    callback anc-calibrate();
    callback frame-tick();
    // Training tab
    callback rtl-connect();
    callback rtl-start-scan();
    callback rtl-stop-scan();
    callback training-start();
    callback training-stop();
    // SDR tab
    callback set-sdr-center(float);
    callback set-sdr-gain(float);
    callback tune-to-harmonic(int);
    callback export-evidence();
    // Mamba safety
    callback mamba-toggle-emergency();
    callback smart-anc-set-blend(float);
    // Manual recording (REC button)
    callback manual-rec-start();
    callback manual-rec-stop();
    callback manual-rec-save();
    // Memos
    callback memo-add(string, string);  // tag, content
    callback memo-delete(int);           // index
    callback memo-export();

    // ── Derived display ───────────────────────────────────────────────────────
    property <string> mode-name:
        current-mode == 1 ? "ANTI-\u{03C6}" : current-mode == 2 ? "NOISE" : current-mode == 3 ? "TONE" : current-mode == 4 ? "SWEEP" : current-mode == 5 ? "ANC-\u{03C6}" : "OFF";
    property <color> mode-color:
        current-mode == 0 ? Pal.lo : current-mode == 2 ? Pal.amber : current-mode == 4 ? Pal.orange : current-mode == 5 ? Pal.green : Pal.cyan;
    property <bool> anc-ok: anc-status != "ANC uncalibrated";

    // ─── Root layout: header / body / footer ──────────────────────────────────
    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // ══════════════════════════════════ HEADER ════════════════════════════
        Rectangle {
            height: 48px;
            background: Pal.surface;

            // bottom border
            Rectangle {
                y: 47px;
                height: 1px;
                background: Pal.border;
            }

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 18px;
                alignment: center;

                // Brand
                Text {
                    text: "Twister";
                    color: Pal.cyan;
                    font-size: 18px;
                    font-weight: 900;
                    letter-spacing: 5px;
                    font-family: "Consolas";
                    vertical-alignment: center;
                }

                Text {
                    text: "v0.5";
                    color: Pal.lo;
                    font-size: 10px;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                // ── Tab bar ───
                Rectangle {
                    width: 12px;
                }

                Chip {
                    label: "TWISTER";
                    active: active-tab == 0;
                    accent: Pal.cyan;
                    width: 72px;
                    clicked => {
                        active-tab = 0;
                    }
                }

                Chip {
                    label: "TRAINING";
                    active: active-tab == 1;
                    accent: Pal.purple;
                    width: 88px;
                    clicked => {
                        active-tab = 1;
                    }
                }

                Chip {
                    label: "MEMOS";
                    active: active-tab == 2;
                    accent: Pal.cyan;
                    width: 72px;
                    clicked => {
                        active-tab = 2;
                    }
                }

                Chip {
                    label: "ANALYSIS";
                    active: active-tab == 3;
                    accent: Pal.green;
                    width: 88px;
                    clicked => {
                        active-tab = 3;
                    }
                }

                Chip {
                    label: "CONSOLE";
                    active: active-tab == 4;
                    accent: Pal.amber;
                    width: 88px;
                    clicked => {
                        active-tab = 4;
                    }
                }

                Chip {
                    label: "CONTROLS";
                    active: active-tab == 5;
                    accent: Pal.cyan;
                    width: 88px;
                    clicked => {
                        active-tab = 5;
                    }
                }

                Chip {
                    label: "JOYCON";
                    active: active-tab == 6;
                    accent: Pal.purple;
                    width: 88px;
                    clicked => {
                        active-tab = 6;
                    }
                }

                // Central freq display
                Rectangle {
                    horizontal-stretch: 1;
                }

                HorizontalLayout {
                    spacing: 14px;
                    alignment: center;
                    VerticalLayout {
                        alignment: center;
                        Lbl {
                            text: "DETECTED";
                            horizontal-alignment: center;
                        }

                        // Fixed-width frequency display (prevents layout jumping)
                        HorizontalLayout {
                            width: 160px;
                            alignment: center;
                            Text {
                                text: detected-freq >= 1000000.0 ? (round(detected-freq / 1000.0) / 1000.0) + " MHz" : detected-freq >= 1000.0 ? (round(detected-freq / 100.0) / 10.0) + " kHz" : round(detected-freq) + " Hz";
                                color: Pal.cyan;
                                font-size: 21px;
                                font-weight: 900;
                                font-family: "Consolas";
                                horizontal-alignment: right;
                                width: 100%;
                            }
                        }

                        // Twister: snapped note name + cents offset
                        HorizontalLayout {
                            alignment: center;
                            spacing: 6px;
                            Text {
                                text: note-name;
                                color: Pal.purple;
                                font-size: 14px;
                                font-weight: 900;
                                font-family: "Consolas";
                                horizontal-alignment: center;
                            }

                            Text {
                                text: note-cents >= 0.0 ? "+" + round(note-cents) + "¢" : round(note-cents) + "¢";
                                color: note-cents > 30.0 || note-cents < -30.0 ? Pal.amber : Pal.mid;
                                font-size: 10px;
                                font-weight: 600;
                                font-family: "Consolas";
                                vertical-alignment: center;
                            }
                        }
                    }

                    Text {
                        text: "\u{2192}";
                        color: mode-color;
                        font-size: 18px;
                        vertical-alignment: center;
                    }

                    // Mode badge
                    Rectangle {
                        width: 88px;
                        height: 38px;
                        border-radius: 7px;
                        background: mode-color.with-alpha(0.12);
                        border-color: mode-color.with-alpha(0.7);
                        border-width: 1.5px;
                        animate background { duration: 120ms; }
                        animate border-color { duration: 120ms; }
                        Text {
                            text: mode-name;
                            color: mode-color;
                            font-size: 13px;
                            font-weight: 900;
                            letter-spacing: 2px;
                            font-family: "Consolas";
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                }

                // System stats
                HorizontalLayout {
                    spacing: 18px;
                    alignment: center;
                    VerticalLayout {
                        alignment: center;
                        Lbl {
                            text: "FRAME";
                            horizontal-alignment: center;
                        }

                        Mon {
                            text: frame-count;
                            font-size: 10px;
                            horizontal-alignment: center;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        Lbl {
                            text: "DISPATCH";
                            horizontal-alignment: center;
                        }

                        Mon {
                            text: (round(dispatch-ms * 10.0) / 10.0) + " ms";
                            font-size: 10px;
                            horizontal-alignment: center;
                            color: dispatch-ms > 20.0 ? Pal.red : dispatch-ms > 10.0 ? Pal.amber : Pal.green;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        Lbl {
                            text: "MICS";
                            horizontal-alignment: center;
                        }

                        Mon {
                            text: input-device-count;
                            font-size: 10px;
                            horizontal-alignment: center;
                        }
                    }
                }

                // START / STOP button
                Rectangle {
                    width: 90px;
                    height: 34px;
                    border-radius: 6px;
                    background: is-running ? Pal.red.with-alpha(0.14) : Pal.green.with-alpha(0.14);
                    border-color: is-running ? Pal.red : Pal.green;
                    border-width: 1.5px;
                    animate background { duration: 120ms; }
                    Text {
                        text: is-running ? "\u{25A0}  STOP" : "\u{25BA}  START";
                        color: is-running ? Pal.red : Pal.green;
                        font-size: 11px;
                        font-weight: 800;
                        letter-spacing: 1px;
                        font-family: "Consolas";
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            toggle-running();
                        }
                    }
                }
            }
        }

        // ══════════════════════════════════ BODY ══════════════════════════════
        if active-tab == 0: HorizontalLayout {
            padding: 8px;
            spacing: 8px;
            vertical-stretch: 1;

            // ════════ LEFT: Controls (205 px) ════════════════════════════════
            VerticalLayout {
                width: 205px;
                spacing: 6px;

                // MODE
                Card {
                    height: 128px;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 6px;
                        Lbl {
                            text: "DENIAL MODE";
                        }

                        HorizontalLayout {
                            spacing: 4px;
                            Chip {
                                label: "OFF";
                                active: current-mode == 0;
                                accent: Pal.lo;
                                horizontal-stretch: 1;
                                clicked => {
                                    set-mode(0);
                                }
                            }

                            Chip {
                                label: "ANTI";
                                active: current-mode == 1;
                                accent: Pal.cyan;
                                horizontal-stretch: 1;
                                clicked => {
                                    set-mode(1);
                                }
                            }

                            Chip {
                                label: "NOISE";
                                active: current-mode == 2;
                                accent: Pal.amber;
                                horizontal-stretch: 1;
                                clicked => {
                                    set-mode(2);
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 4px;
                            Chip {
                                label: "TONE";
                                active: current-mode == 3;
                                accent: Pal.cyan;
                                horizontal-stretch: 1;
                                clicked => {
                                    set-mode(3);
                                }
                            }

                            Chip {
                                label: "SWEEP";
                                active: current-mode == 4;
                                accent: Pal.orange;
                                horizontal-stretch: 1;
                                clicked => {
                                    set-mode(4);
                                }
                            }

                            Chip {
                                label: "ANC-p";
                                active: current-mode == 5;
                                accent: Pal.green;
                                horizontal-stretch: 1;
                                clicked => {
                                    set-mode(5);
                                }
                            }
                        }

                        HorizontalLayout {
                            alignment: center;
                            Lbl {
                                text: "AUTO-TUNE";
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Toggle {
                                on: auto-tune-active;
                                accent: Pal.cyan;
                                toggled => {
                                    toggle-auto-tune();
                                }
                            }
                        }
                    }
                }

                // MANUAL RECORDING (REC)
                Card {
                    height: 96px;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 6px;
                        alignment: space-between;
                        HorizontalLayout {
                            alignment: center;
                            spacing: 4px;
                            Mon {
                                text: manual-rec-active ? "● RECORDING" : "● REC";
                                font-size: 12px;
                                font-weight: 700;
                                color: manual-rec-active ? Pal.red : Pal.cyan;
                            }
                        }

                        Text {
                            text: manual-rec-status;
                            color: Pal.lo;
                            font-size: 9px;
                            font-weight: 400;
                            horizontal-alignment: center;
                        }

                        HorizontalLayout {
                            spacing: 4px;
                            Chip {
                                label: manual-rec-active ? "■ STOP" : "▸ START";
                                active: manual-rec-active;
                                accent: manual-rec-active ? Pal.red : Pal.green;
                                horizontal-stretch: 1;
                                clicked => {
                                    if manual-rec-active {
                                        manual-rec-stop();
                                    } else {
                                        manual-rec-start();
                                    }
                                }
                            }
                        }

                        TextInput {
                            single-line: true;
                            text <=> manual-rec-notes;
                            color: Pal.hi;
                            selection-background-color: Pal.cyan.with-alpha(0.3);
                        }
                    }
                }

                // MASTER GAIN
                Card {
                    height: 64px;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 4px;
                        HorizontalLayout {
                            Lbl {
                                text: "MASTER GAIN";
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Mon {
                                text: round(master-gain * 100.0) + "%";
                                font-size: 10px;
                            }
                        }

                        Slider {
                            minimum: 0.0;
                            maximum: 1.0;
                            value: master-gain;
                            changed(v) => {
                                set-gain(v);
                            }
                        }
                    }
                }

                // WAVESHAPE
                Card {
                    height: 102px;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 6px;
                        Lbl {
                            text: "WAVESHAPE";
                        }

                        HorizontalLayout {
                            spacing: 3px;
                            Chip {
                                label: "SIN";
                                active: waveshape-mode == 0;
                                horizontal-stretch: 1;
                                clicked => {
                                    set-waveshape(0);
                                }
                            }

                            Chip {
                                label: "SQ";
                                active: waveshape-mode == 1;
                                horizontal-stretch: 1;
                                clicked => {
                                    set-waveshape(1);
                                }
                            }

                            Chip {
                                label: "TRI";
                                active: waveshape-mode == 2;
                                horizontal-stretch: 1;
                                clicked => {
                                    set-waveshape(2);
                                }
                            }

                            Chip {
                                label: "SAW";
                                active: waveshape-mode == 3;
                                horizontal-stretch: 1;
                                clicked => {
                                    set-waveshape(3);
                                }
                            }

                            Chip {
                                label: "SCL";
                                active: waveshape-mode == 4;
                                accent: Pal.orange;
                                horizontal-stretch: 1;
                                clicked => {
                                    set-waveshape(4);
                                }
                            }
                        }

                        HorizontalLayout {
                            Lbl {
                                text: "DRIVE";
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Mon {
                                text: round(waveshape-drive * 100.0) + "%";
                                font-size: 10px;
                            }
                        }

                        Slider {
                            minimum: 0.0;
                            maximum: 1.0;
                            value: waveshape-drive;
                            changed(v) => {
                                set-waveshape-drive(v);
                            }
                        }
                    }
                }

                // PDM WIDEBAND
                Card {
                    height: 82px;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 6px;
                        HorizontalLayout {
                            Lbl {
                                text: "PDM WIDEBAND";
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Toggle {
                                on: pdm-active;
                                accent: Pal.purple;
                                toggled => {
                                    toggle-pdm();
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            VerticalLayout {
                                Lbl {
                                    text: "CLOCK";
                                }

                                Mon {
                                    text: pdm-clock-mhz + " MHz";
                                    font-size: 10px;
                                    color: pdm-active ? Pal.purple : Pal.lo;
                                }
                            }

                            VerticalLayout {
                                Lbl {
                                    text: "OS";
                                }

                                Mon {
                                    text: oversample-ratio + "x";
                                    font-size: 10px;
                                    color: pdm-active ? Pal.purple : Pal.lo;
                                }
                            }

                            VerticalLayout {
                                Lbl {
                                    text: "SNR";
                                }

                                Mon {
                                    text: (round(pdm-snr-db * 10.0) / 10.0) + " dB";
                                    font-size: 10px;
                                    color: pdm-snr-db > 25.0 ? Pal.green : pdm-snr-db > 10.0 ? Pal.amber : Pal.lo;
                                }
                            }
                        }
                    }
                }

                // BEAM FOCUS
                Card {
                    height: 64px;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 4px;
                        HorizontalLayout {
                            Lbl {
                                text: "BEAM FOCUS";
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Mon {
                                text: round(beam-focus-deg) + " deg";
                                font-size: 10px;
                            }
                        }

                        Slider {
                            minimum: 1.0;
                            maximum: 180.0;
                            value: beam-focus-deg;
                            changed(v) => {
                                set-beam-focus(v);
                            }
                        }
                    }
                }

                // MAMBA SAFETY
                Card {
                    height: 110px;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 6px;
                        HorizontalLayout {
                            Lbl {
                                text: "MAMBA SAFETY";
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: mamba-emergency-off ? "\u{26A0} KILLED" : "\u{2713} LIVE";
                                color: mamba-emergency-off ? Pal.red : Pal.green;
                                font-size: 9px;
                                font-weight: 800;
                                font-family: "Consolas";
                                vertical-alignment: center;
                            }
                        }

                        HorizontalLayout {
                            Lbl {
                                text: "EMERGENCY OFF";
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Toggle {
                                on: mamba-emergency-off;
                                accent: Pal.red;
                                toggled => {
                                    mamba-toggle-emergency();
                                }
                            }
                        }

                        HorizontalLayout {
                            Lbl {
                                text: "SMART ANC";
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Mon {
                                text: round(smart-anc-blend * 100.0) + "%";
                                font-size: 10px;
                                color: smart-anc-blend > 0.0 ? Pal.purple : Pal.lo;
                            }
                        }

                        Slider {
                            minimum: 0.0;
                            maximum: 1.0;
                            value: smart-anc-blend;
                            changed(v) => {
                                smart-anc-set-blend(v);
                            }
                        }
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }
            }

            // ════════ CENTRE: Spectrum + Waterfall ═══════════════════════════
            VerticalLayout {
                spacing: 6px;
                horizontal-stretch: 1;

                // SPECTRUM — SVG path waveform, resolution-independent
                // Three filled paths share the same coordinate space (0..1000 × 0..100).
                // Built each frame in main.rs as "M x0 y0 L x1 y1 ... L xN 100 Z".
                // FemtoVG anti-aliases each path as a single filled polygon — no per-bar draw calls.
                Card {
                    height: 88px;
                    VerticalLayout {
                        padding: 8px;
                        spacing: 5px;
                        HorizontalLayout {
                            Lbl {
                                text: "SPECTRUM   1 Hz";
                                vertical-alignment: center;
                            }

                            Text {
                                text: " -- " + waterfall-max-freq;
                                color: pdm-active ? Pal.purple : Pal.lo;
                                font-size: 9px;
                                font-weight: 700;
                                letter-spacing: 1px;
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: pdm-active ? "PDM WIDEBAND" : "BASEBAND";
                                color: pdm-active ? Pal.purple : Pal.lo;
                                font-size: 8px;
                                font-weight: 700;
                                letter-spacing: 1.5px;
                                vertical-alignment: center;
                            }
                        }
                        // Path canvas — 3 overlapping filled paths in the same coordinate space.
                        // viewbox maps 0..1000 × 0..100 onto the element's pixel dimensions.
                        Rectangle {
                            vertical-stretch: 1;
                            clip: true;
                            background: Pal.border.with-alpha(0.12);
                            // Red (high freq, 171-255) drawn first so green/cyan paint over it
                            Path {
                                x: 0;
                                y: 0;
                                width: parent.width;
                                height: parent.height;
                                viewbox-x: 0;
                                viewbox-y: 0;
                                viewbox-width: 1000;
                                viewbox-height: 100;
                                commands: spectrum-path-red;
                                fill: transparent;
                                stroke: Pal.red;
                                stroke-width: 1.5px;
                                anti-alias: true;
                            }

                            Path {
                                x: 0;
                                y: 0;
                                width: parent.width;
                                height: parent.height;
                                viewbox-x: 0;
                                viewbox-y: 0;
                                viewbox-width: 1000;
                                viewbox-height: 100;
                                commands: spectrum-path-cyan;
                                fill: transparent;
                                stroke: Pal.cyan;
                                stroke-width: 1.5px;
                                anti-alias: true;
                            }

                            Path {
                                x: 0;
                                y: 0;
                                width: parent.width;
                                height: parent.height;
                                viewbox-x: 0;
                                viewbox-y: 0;
                                viewbox-width: 1000;
                                viewbox-height: 100;
                                commands: spectrum-path-green;
                                fill: transparent;
                                stroke: Pal.green;
                                stroke-width: 1.5px;
                                anti-alias: true;
                            }
                        }
                    }
                }

                // WATERFALL
                Card {
                    vertical-stretch: 1;
                    VerticalLayout {
                        padding: 6px;
                        spacing: 4px;
                        HorizontalLayout {
                            Lbl {
                                text: "WATERFALL  ·  3D";
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: waterfall-max-freq;
                                color: Pal.lo;
                                font-size: 9px;
                                vertical-alignment: center;
                            }
                        }

                        // Single Image element — one texture upload per frame, bilinearly
                        // scaled by FemtoVG to fill any window size without pixelation.
                        Image {
                            vertical-stretch: 1;
                            source: waterfall-image;
                            image-fit: fill;
                        }

                        HorizontalLayout {
                            Text {
                                text: "1 Hz";
                                color: Pal.lo;
                                font-size: 9px;
                                font-family: "Consolas";
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: waterfall-mid-freq;
                                color: Pal.lo;
                                font-size: 9px;
                                font-family: "Consolas";
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: waterfall-max-freq;
                                color: Pal.lo;
                                font-size: 9px;
                                font-family: "Consolas";
                            }
                        }
                    }
                }

                // OSCILLOSCOPE WAVEFORM — Investigative Time-Domain View
                Card {
                    height: 100px;
                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;
                        HorizontalLayout {
                            Lbl {
                                text: "OSCILLOSCOPE WAVEFORM  ·  INVESTIGATION";
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Text {
                                // Displays the "Tazer" component (DC Bias) detected in src/audio.rs
                                text: "CENTER BIAS: " + (round(audio-dc-bias * 100.0) / 100.0);
                                color: audio-dc-bias > 0.05 ? Pal.red : Pal.lo;
                                font-size: 9px;
                                font-weight: 700;
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                            background: Pal.border.with-alpha(0.12);
                            clip: true;
                            Path {
                                width: parent.width;
                                height: parent.height;
                                viewbox-x: 0;
                                viewbox-y: 0;
                                viewbox-width: 100;
                                viewbox-height: 100;
                                commands: waveform-path;
                                stroke: Pal.cyan;
                                stroke-width: 1.5px;
                                anti-alias: true;
                            }
                        }
                    }
                }
            }

            // ════════ RIGHT: Status panels (248 px) ══════════════════════════
            VerticalLayout {
                width: 248px;
                spacing: 6px;

                // BISPECTRUM
                Card {
                    height: 82px;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 5px;
                        Lbl {
                            text: "BISPECTRUM DETECTOR";
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            VerticalLayout {
                                Lbl {
                                    text: "PEAK FREQ";
                                }

                                HorizontalLayout {
                                    width: 90px;
                                    Mon {
                                        text: detected-freq >= 1000.0 ? (round(detected-freq / 100.0) / 10.0) + " kHz" : round(detected-freq) + " Hz";
                                        font-size: 11px;
                                        color: Pal.cyan;
                                        width: 100%;
                                        horizontal-alignment: right;
                                    }
                                }
                            }

                            VerticalLayout {
                                Lbl {
                                    text: "DENIAL MODE";
                                }

                                Mon {
                                    text: mode-name;
                                    font-size: 11px;
                                    color: mode-color;
                                }
                            }
                        }

                        HBar {
                            frac: clamp(detected-freq / 96000.0, 0.0, 1.0);
                            bar-color: Pal.cyan;
                            warn_at: 1.1;
                        }
                    }
                }

                // ANC PHASE CORRECTION
                Card {
                    height: 130px;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 6px;
                        HorizontalLayout {
                            Lbl {
                                text: "ANC PHASE CORRECTION";
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Rectangle {
                                width: 8px;
                                height: 8px;
                                border-radius: 4px;
                                background: anc-ok ? Pal.green : Pal.amber;
                            }
                        }

                        Text {
                            text: anc-status;
                            color: anc-ok ? Pal.green : Pal.amber;
                            font-size: 10px;
                            font-family: "Consolas";
                            wrap: word-wrap;
                        }

                        HorizontalLayout {
                            Lbl {
                                text: "LMS FILTER";
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Mon {
                                text: anc-ok ? "ACTIVE" : "IDLE";
                                font-size: 9px;
                                color: anc-ok ? Pal.green : Pal.lo;
                            }
                        }
                        // CALIBRATE button
                        Rectangle {
                            height: 30px;
                            border-radius: 5px;
                            background: current-mode == 5 ? Pal.green.with-alpha(0.14) : Pal.border.with-alpha(0.5);
                            border-color: current-mode == 5 ? Pal.green : Pal.border;
                            border-width: 1px;
                            animate background { duration: 80ms; }
                            Text {
                                text: "CALIBRATE";
                                color: current-mode == 5 ? Pal.green : Pal.lo;
                                font-size: 10px;
                                font-weight: 800;
                                letter-spacing: 2px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            TouchArea {
                                enabled: current-mode == 5;
                                clicked => {
                                    anc-calibrate();
                                }
                            }
                        }
                    }
                }

                // TDOA BEAMFORMING
                Card {
                    height: 170px;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 6px;
                        Lbl {
                            text: "TDOA BEAMFORMING";
                        }

                        Rectangle {
                            height: 104px;
                            // outer ring
                            Rectangle {
                                property <length> r: 46px;
                                x: (parent.width - 2 * r) / 2;
                                y: 2px;
                                width: 2 * r;
                                height: 2 * r;
                                border-radius: r;
                                background: Pal.border.with-alpha(0.3);
                                border-color: Pal.border;
                                border-width: 1px;

                                // Cardinal labels
                                Text {
                                    x: r - 4px;
                                    y: 2px;
                                    text: "N";
                                    color: Pal.lo;
                                    font-size: 8px;
                                }

                                Text {
                                    x: r - 4px;
                                    y: 2 * r - 14px;
                                    text: "S";
                                    color: Pal.lo;
                                    font-size: 8px;
                                }

                                Text {
                                    x: 2px;
                                    y: r - 6px;
                                    text: "W";
                                    color: Pal.lo;
                                    font-size: 8px;
                                }

                                Text {
                                    x: 2 * r - 12px;
                                    y: r - 6px;
                                    text: "E";
                                    color: Pal.lo;
                                    font-size: 8px;
                                }

                                // Azimuth needle tip dot
                                property <angle> az: (beam-azimuth-deg - 90) * 1deg;
                                Rectangle {
                                    width: 8px;
                                    height: 8px;
                                    border-radius: 4px;
                                    x: 46px + 34px * cos(parent.az) - 4px;
                                    y: 46px - 34px * sin(parent.az) - 4px;
                                    background: beam-confidence > 0.25 ? Pal.cyan : Pal.lo;
                                    animate background { duration: 200ms; }
                                }
                                // Center dot
                                Rectangle {
                                    width: 5px;
                                    height: 5px;
                                    border-radius: 2.5px;
                                    x: 46px - 2.5px;
                                    y: 46px - 2.5px;
                                    background: Pal.cyan;
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 12px;
                            VerticalLayout {
                                Lbl {
                                    text: "AZIMUTH";
                                }

                                Mon {
                                    text: (round(beam-azimuth-deg * 10.0) / 10.0) + " deg";
                                    font-size: 11px;
                                    color: Pal.cyan;
                                }
                            }

                            VerticalLayout {
                                Lbl {
                                    text: "CONFIDENCE";
                                }

                                Mon {
                                    text: round(beam-confidence * 100.0) + "%";
                                    font-size: 11px;
                                    color: beam-confidence > 0.7 ? Pal.green : beam-confidence > 0.3 ? Pal.amber : Pal.lo;
                                }
                            }
                        }
                    }
                }

                // MAMBA AUTOENCODER latent visualization
                Card {
                    height: 108px;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 5px;
                        HorizontalLayout {
                            Lbl {
                                text: "IQU-MAMBA  LATENT-32";
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: latent-embedding.length > 0 && latent-embedding.length == 64 ? "ONLINE" : "OFFLINE";
                                color: latent-embedding.length > 0 && latent-embedding.length == 64 ? Pal.green : Pal.amber;
                                font-size: 8px;
                                font-weight: 800;
                                letter-spacing: 1px;
                                vertical-alignment: center;
                            }
                        }
                        // 64-bin latent vector visualization (live from Mamba model)
                        HorizontalLayout {
                            spacing: 1px;
                            for val in latent-embedding: VBar {
                                frac: clamp((val + 1.0) / 2.0, 0.0, 1.0);  // Map [-1,1] to [0,1]
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }
                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            VBar {
                                frac: 0.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }
                        }

                        Text {
                            text: "Burn WGPU  d=64  L=4  latent=32";
                            color: Pal.lo;
                            font-size: 9px;
                            font-family: "Consolas";
                        }

                        Text {
                            text: "Awaiting trained weights (mamba.rs stub)";
                            color: Pal.lo;
                            font-size: 9px;
                        }
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }
            }
        }

        // ═══════════════════════ TRAINING TAB ═════════════════════════════════
        if active-tab == 1: HorizontalLayout {
            padding: 8px;
            spacing: 8px;
            vertical-stretch: 1;

            // ════ LEFT: RTL-SDR Controls ══════════════════════════════════════
            Card {
                width: 260px;
                VerticalLayout {
                    padding: 12px;
                    spacing: 10px;
                    Text {
                        text: "RTL-SDR";
                        color: Pal.cyan;
                        font-size: 14px;
                        font-weight: 900;
                        letter-spacing: 2px;
                        font-family: "Consolas";
                    }

                    // Connection status
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            y: 4px;
                            background: rtl-connected ? Pal.green : Pal.red;
                        }

                        Mon {
                            text: rtl-connected ? "CONNECTED" : "NOT FOUND";
                            font-size: 10px;
                            color: rtl-connected ? Pal.green : Pal.red;
                        }
                    }

                    // Connect button
                    Chip {
                        label: "CONNECT RTL-SDR";
                        active: rtl-connected;
                        accent: Pal.green;
                        width: 140px;
                        clicked => {
                            rtl-connect();
                        }
                    }

                    Rectangle {
                        height: 4px;
                    }

                    // Center frequency
                    Lbl {
                        text: "CENTER FREQ";
                    }

                    HorizontalLayout {
                        width: 120px;
                        Mon {
                            text: rtl-freq-mhz >= 1.0 ? (round(rtl-freq-mhz * 1000.0) / 1000.0) + " MHz" : (round(rtl-freq-mhz * 1000000.0) / 1000.0) + " kHz";
                            font-size: 16px;
                            color: Pal.cyan;
                            width: 100%;
                            horizontal-alignment: right;
                        }
                    }

                    Rectangle {
                        height: 4px;
                    }

                    // Scan controls
                    Lbl {
                        text: "FREQUENCY SCAN";
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        Chip {
                            label: rtl-scanning ? "■ STOP" : "▸ SCAN";
                            active: rtl-scanning;
                            accent: Pal.orange;
                            width: 80px;
                            clicked => {
                                if rtl-scanning {
                                    rtl-stop-scan();
                                } else {
                                    rtl-start-scan();
                                }
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            Mon {
                                text: "10 kHz → 300 MHz";
                                font-size: 9px;
                                color: Pal.lo;
                            }
                        }
                    }

                    Rectangle {
                        height: 8px;
                    }

                    // Training pair count
                    Lbl {
                        text: "PAIRS COLLECTED";
                    }

                    Mon {
                        text: training-pairs;
                        font-size: 16px;
                        color: Pal.purple;
                    }

                    Rectangle {
                        height: 12px;
                    }

                    // DC Offset Forensic Monitoring
                    Lbl {
                        text: "DC BIAS";
                    }

                    Mon {
                        text: "RF: " + (round(sdr-dc-bias * 1000.0) / 1000.0);
                        font-size: 12px;
                        color: sdr-dc-bias > 0.8 ? Pal.red : Pal.lo;
                    }

                    Mon {
                        text: "AUDIO: " + (round(audio-dc-bias * 1000.0) / 1000.0) + "V";
                        font-size: 12px;
                        color: audio-dc-bias > 0.1 ? Pal.red : Pal.lo;
                    }

                    Rectangle {
                        vertical-stretch: 1;
                    }
                }
            }

            // ════ CENTER: TX/RX Spectra ═══════════════════════════════════════
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 8px;

                // TX spectrum (soundcard PDM wideband output)
                Card {
                    vertical-stretch: 1;
                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;
                        HorizontalLayout {
                            spacing: 8px;
                            Lbl {
                                text: "TX · SOUNDCARD PDM WIDEBAND";
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Mon {
                                text: "0 → 12.288 MHz";
                                font-size: 9px;
                                color: Pal.lo;
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1.0;
                            background: Pal.bg;
                            border-radius: 4px;
                            clip: true;
                            Path {
                                width: parent.width;
                                height: parent.height;
                                viewbox-x: 0.0;
                                viewbox-y: 0.0;
                                viewbox-width: 1000.0;
                                viewbox-height: 100.0;
                                fill: Pal.cyan.with-alpha(0.15);
                                stroke: Pal.cyan;
                                stroke-width: 1.5px;
                                commands: tx-spectrum-path;
                            }

                            Path {
                                width: parent.width;
                                height: parent.height;
                                viewbox-x: 0.0;
                                viewbox-y: 0.0;
                                viewbox-width: 1000.0;
                                viewbox-height: 100.0;
                                commands: reconstruction-path;
                                stroke: Pal.orange;
                                stroke-width: 2px;
                                anti-alias: true;
                            }
                        }
                    }
                }

                // RX spectrum (RTL-SDR received)
                Card {
                    vertical-stretch: 1;
                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;
                        HorizontalLayout {
                            spacing: 8px;
                            Lbl {
                                text: "RX · RTL-SDR ANTENNA";
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Mon {
                                text: (round(rtl-freq-mhz * 1000.0) / 1000.0) + " MHz ± BW";
                                font-size: 9px;
                                color: Pal.lo;
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1.0;
                            background: Pal.bg;
                            border-radius: 4px;
                            clip: true;
                            Path {
                                width: parent.width;
                                height: parent.height;
                                viewbox-x: 0.0;
                                viewbox-y: 0.0;
                                viewbox-width: 1000.0;
                                viewbox-height: 100.0;
                                fill: Pal.orange.with-alpha(0.15);
                                stroke: Pal.orange;
                                stroke-width: 1.5px;
                                commands: rtl-spectrum-path;
                            }
                        }
                    }
                }
            }

            // ════ RIGHT: Mamba Training ═══════════════════════════════════════
            Card {
                width: 240px;
                VerticalLayout {
                    padding: 12px;
                    spacing: 10px;
                    Text {
                        text: "MAMBA";
                        color: Pal.purple;
                        font-size: 14px;
                        font-weight: 900;
                        letter-spacing: 2px;
                        font-family: "Consolas";
                    }

                    Mon {
                        text: "IQU AUTOENCODER";
                        font-size: 9px;
                        color: Pal.lo;
                    }

                    Rectangle {
                        height: 6px;
                    }

                    // Status
                    Lbl {
                        text: "STATUS";
                    }

                    Mon {
                        text: training-active ? "TRAINING" : "IDLE";
                        font-size: 12px;
                        color: training-active ? Pal.green : Pal.lo;
                    }

                    // Epoch
                    Lbl {
                        text: "EPOCH";
                    }

                    Mon {
                        text: training-epoch;
                        font-size: 16px;
                        color: Pal.purple;
                    }

                    // Loss
                    Lbl {
                        text: "LOSS";
                    }

                    HorizontalLayout {
                        width: 100%;
                        Mon {
                            text: (round(training-loss * 10000.0) / 10000.0);
                            font-size: 16px;
                            color: training-loss < 0.01 ? Pal.green : training-loss < 0.1 ? Pal.amber : Pal.red;
                            width: 80px;
                            horizontal-alignment: right;
                        }
                    }

                    HBar {
                        frac: clamp(1.0 - training-loss, 0.0, 1.0);
                        bar-color: Pal.purple;
                        warn_at: 1.1;
                    }

                    Rectangle {
                        height: 8px;
                    }

                    // Anomaly Score
                    Lbl {
                        text: "ANOMALY SCORE";
                    }

                    HorizontalLayout {
                        width: 100%;
                        Mon {
                            text: (round(mamba-anomaly * 100.0) / 100.0) + " dB";
                            font-size: 14px;
                            color: mamba-anomaly < 0.0 ? Pal.green : mamba-anomaly < 5.0 ? Pal.amber : Pal.red;
                            width: 100px;
                            horizontal-alignment: right;
                        }
                    }

                    HBar {
                        frac: clamp((mamba-anomaly + 20.0) / 20.0, 0.0, 1.0);
                        bar-color: mamba-anomaly < 0.0 ? Pal.green : mamba-anomaly < 5.0 ? Pal.amber : Pal.red;
                        warn_at: 1.1;
                    }

                    Rectangle {
                        height: 8px;
                    }

                    // Loss History Label
                    Lbl {
                        text: "LOSS HISTORY";
                    }

                    // Loss history sparkline (visualize array as simple bar chart)
                    Card {
                        height: 60px;
                        HorizontalLayout {
                            padding: 4px;
                            spacing: 1px;
                            for loss in loss-history: Rectangle {
                                vertical-stretch: clamp(1.0 - loss * 10.0, 0.0, 1.0);
                                background: Pal.purple;
                                opacity: 0.7;
                            }
                        }
                    }

                    Mon {
                        text: loss-history.length + " samples";
                        font-size: 8px;
                        color: Pal.lo;
                    }

                    Rectangle {
                        height: 8px;
                    }

                    // Start / Pause
                    Chip {
                        label: training-active ? "■ PAUSE" : "▸ START TRAINING";
                        active: training-active;
                        accent: Pal.green;
                        width: 150px;
                        clicked => {
                            if training-active {
                                training-stop();
                            } else {
                                training-start();
                            }
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                    }

                    // GATE STATUS
                    Lbl {
                        text: "GATE STATUS";
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        Mon {
                            text: gate-status;
                            color: gate-status == "FORWARD" ? Pal.green : gate-status == "REJECTED" ? Pal.red : Pal.lo;
                            font-size: 14px;
                        }
                    }

                    Mon {
                        text: last-gate-reason;
                        color: Pal.lo;
                        font-size: 9px;
                        wrap: word-wrap;
                    }

                    Rectangle {
                        height: 8px;
                    }

                    Lbl {
                        text: "QUEUE DIAGNOSTICS";
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        VerticalLayout {
                            Lbl {
                                text: "DROPPED";
                            }

                            Mon {
                                text: training-pairs-dropped;
                                color: training-pairs-dropped > 0 ? Pal.red : Pal.lo;
                                font-size: 10px;
                            }
                        }

                        VerticalLayout {
                            Lbl {
                                text: "REJ(ANOM)";
                            }

                            Mon {
                                text: gate-rejections-low-anomaly;
                                color: Pal.lo;
                                font-size: 10px;
                            }
                        }

                        VerticalLayout {
                            Lbl {
                                text: "REJ(CONF)";
                            }

                            Mon {
                                text: gate-rejections-low-confidence;
                                color: Pal.lo;
                                font-size: 10px;
                            }
                        }
                    }

                    Rectangle {
                        height: 8px;
                    }
                    // Pairs indicator
                    Lbl {
                        text: "TRAINING PAIRS";
                    }

                    HBar {
                        frac: clamp(training-pairs / 1000.0, 0.0, 1.0);
                        bar-color: Pal.cyan;
                        warn_at: 1.1;
                    }

                    Mon {
                        text: training-pairs + " / 1000";
                        font-size: 9px;
                        color: Pal.lo;
                    }
                }
            }
        }

        // ═══════════════════════ MEMOS TAB ═════════════════════════════════════
        if active-tab == 2: HorizontalLayout {
            padding: 8px;
            spacing: 8px;
            vertical-stretch: 1;

            // ════════ MAIN: Memo Cards (scrollable) ═══════════════════════════════
            VerticalLayout {
                spacing: 8px;
                horizontal-stretch: 1;

                // Input section
                Card {
                    height: 110px;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 6px;
                        Lbl {
                            text: "NEW MEMO";
                        }

                        HorizontalLayout {
                            spacing: 6px;
                            alignment: center;
                            Lbl {
                                text: "TAG:";
                            }

                            Chip {
                                label: "NOTE";
                                active: memo-input-tag == "NOTE";
                                accent: Pal.purple;
                                width: 70px;
                                clicked => {
                                    memo-input-tag = "NOTE";
                                }
                            }

                            Chip {
                                label: "EVIDENCE";
                                active: memo-input-tag == "EVIDENCE";
                                accent: Pal.cyan;
                                width: 80px;
                                clicked => {
                                    memo-input-tag = "EVIDENCE";
                                }
                            }

                            Chip {
                                label: "ANALYSIS";
                                active: memo-input-tag == "ANALYSIS";
                                accent: Pal.amber;
                                width: 80px;
                                clicked => {
                                    memo-input-tag = "ANALYSIS";
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 6px;
                            TextInput {
                                single-line: true;
                                text <=> memo-input-text;
                                color: Pal.hi;
                                selection-background-color: Pal.cyan.with-alpha(0.3);
                                horizontal-stretch: 1;
                            }

                            Chip {
                                label: "SAVE";
                                accent: Pal.green;
                                width: 60px;
                                clicked => {
                                    memo-add(memo-input-tag, memo-input-text);
                                    memo-input-text = "";
                                }
                            }
                        }

                        Text {
                            text: "Max 80 characters";
                            font-size: 8px;
                            color: Pal.lo;
                            horizontal-alignment: right;
                        }
                    }
                }

                // Search and filter
                Card {
                    height: 50px;
                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;
                        HorizontalLayout {
                            spacing: 6px;
                            TextInput {
                                single-line: true;
                                text <=> memo-search-text;
                                color: Pal.hi;
                                selection-background-color: Pal.cyan.with-alpha(0.3);
                                horizontal-stretch: 1;
                            }
                        }
                    }
                }

                // Memos list (scrollable)
                Card {
                    vertical-stretch: 1;
                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;
                        // Note: In real implementation, this would be a scrollview with memo-timestamps/tags/contents arrays
                        // For now, show placeholder
                        if memo-timestamps.length == 0: Text {
                            text: "No memos yet. Add one above.";
                            color: Pal.lo;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        if memo-timestamps.length > 0: VerticalLayout {
                            spacing: 4px;
                            for i in memo-timestamps.length: MemoCard {
                                timestamp: memo-timestamps[i];
                                tag: memo-tags[i];
                                content: memo-contents[i];
                                show-delete: false;
                                delete-clicked => {
                                    memo-delete(i);
                                }
                            }
                        }
                    }
                }

                // Action buttons
                HorizontalLayout {
                    spacing: 6px;
                    Chip {
                        label: "EXPORT CSV";
                        accent: Pal.amber;
                        width: 100px;
                        clicked => {
                            memo-export();
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                    }

                    Text {
                        text: memo-timestamps.length + " memos";
                        color: Pal.lo;
                        font-size: 9px;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ══════════════════════════════════ FOOTER ════════════════════════════
        Rectangle {
            height: 44px;
            background: Pal.surface;
            Rectangle {
                height: 1px;
                background: Pal.border;
            }

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 0px;
                alignment: center;

                // AGC — auto-gain readout
                HorizontalLayout {
                    spacing: 8px;
                    VerticalLayout {
                        alignment: center;
                        Lbl {
                            text: "AGC AUTO";
                        }

                        HorizontalLayout {
                            width: 60px;
                            Mon {
                                text: "+" + round(agc-gain-db) + " dB";
                                font-size: 10px;
                                color: Pal.cyan;
                                width: 100%;
                                horizontal-alignment: right;
                            }
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        Lbl {
                            text: "SNL";
                        }

                        HorizontalLayout {
                            width: 60px;
                            Mon {
                                text: round(snl-db) + " dB";
                                font-size: 10px;
                                color: Pal.green;
                                width: 100%;
                                horizontal-alignment: right;
                            }
                        }
                    }
                }

                Rectangle {
                    width: 12px;
                }

                Rectangle {
                    width: 1px;
                    height: 28px;
                    background: Pal.border;
                }

                Rectangle {
                    width: 12px;
                }

                // Input
                HorizontalLayout {
                    spacing: 8px;
                    VerticalLayout {
                        alignment: center;
                        Lbl {
                            text: "INPUT PEAK";
                        }

                        HorizontalLayout {
                            width: 70px;
                            Mon {
                                text: round(agc-peak-dbfs) + " dBFS";
                                font-size: 10px;
                                color: agc-peak-dbfs > -6.0 ? Pal.red : Pal.green;
                                width: 100%;
                                horizontal-alignment: right;
                            }
                        }
                    }

                    HBar {
                        width: 100px;
                        frac: clamp((agc-peak-dbfs + 60.0) / 60.0, 0.0, 1.0);
                        bar-color: Pal.green;
                        warn_at: 0.90;
                    }
                }

                Rectangle {
                    width: 12px;
                }

                Rectangle {
                    width: 1px;
                    height: 28px;
                    background: Pal.border;
                }

                Rectangle {
                    width: 12px;
                }

                // Output
                HorizontalLayout {
                    spacing: 8px;
                    VerticalLayout {
                        alignment: center;
                        Lbl {
                            text: "OUTPUT PEAK";
                        }

                        HorizontalLayout {
                            width: 70px;
                            Mon {
                                text: round(output-peak-db) + " dBFS";
                                font-size: 10px;
                                color: output-peak-db > -6.0 ? Pal.red : Pal.cyan;
                                width: 100%;
                                horizontal-alignment: right;
                            }
                        }
                    }

                    HBar {
                        width: 100px;
                        frac: clamp((output-peak-db + 60.0) / 60.0, 0.0, 1.0);
                        bar-color: Pal.cyan;
                        warn_at: 0.90;
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                }

                // PDM SNR
                HorizontalLayout {
                    spacing: 8px;
                    VerticalLayout {
                        alignment: center;
                        Lbl {
                            text: "PDM SNR";
                        }

                        HorizontalLayout {
                            width: 50px;
                            Mon {
                                text: (round(pdm-snr-db * 10.0) / 10.0) + " dB";
                                font-size: 10px;
                                color: pdm-active ? (pdm-snr-db > 25.0 ? Pal.green : Pal.amber) : Pal.lo;
                                width: 100%;
                                horizontal-alignment: right;
                            }
                        }
                    }

                    HBar {
                        width: 80px;
                        frac: clamp(pdm-snr-db / 60.0, 0.0, 1.0);
                        bar-color: Pal.purple;
                        warn_at: 1.1;
                    }
                }

                Rectangle {
                    width: 12px;
                }

                Rectangle {
                    width: 1px;
                    height: 28px;
                    background: Pal.border;
                }

                Rectangle {
                    width: 12px;
                }

                // Export Evidence button
                Rectangle {
                    width: 90px;
                    height: 28px;
                    background: Pal.surface;
                    border-color: Pal.amber;
                    border-radius: 3px;
                    border-width: 1px;
                    animate background { duration: 80ms; }
                    Text {
                        text: "EXPORT";
                        color: Pal.amber;
                        font-size: 10px;
                        font-weight: 800;
                        letter-spacing: 2px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            export-evidence();
                        }
                    }
                }
            }
        }

        // ═══════════════════════ ANALYSIS TAB ══════════════════════════════════
        if active-tab == 3: VerticalLayout {
            padding: 8px;
            spacing: 8px;

            // ═══════════════════ 2×2 GRID OF PANELS ═════════════════════════════
            HorizontalLayout {
                spacing: 8px;
                vertical-stretch: 1;
                horizontal-stretch: 1;

                // ══ LEFT COLUMN ═════════════════════════════════════════════════
                VerticalLayout {
                    spacing: 8px;
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    // ── Panel 1: Temporal Scatter Plot (Time vs Intensity) ─────
                    Card {
                        vertical-stretch: 1;
                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;
                            Text {
                                text: "TEMPORAL EVENTS";
                                color: Pal.cyan;
                                font-size: 14px;
                                font-weight: 900;
                                letter-spacing: 2px;
                                font-family: "Consolas";
                            }

                            Mon {
                                text: "Time (weeks) vs Intensity (0-1)";
                                font-size: 9px;
                                color: Pal.lo;
                            }

                            // Scatter plot area
                            Rectangle {
                                vertical-stretch: 1;
                                background: Pal.bg;
                                border-color: Pal.border;
                                border-width: 1px;
                                border-radius: 4px;
                                clip: true;

                                // Grid lines (background)
                                Path {
                                    width: 100%;
                                    height: 100%;
                                    viewbox-x: 0.0;
                                    viewbox-y: 0.0;
                                    viewbox-width: 100.0;
                                    viewbox-height: 100.0;
                                    stroke: Pal.border;
                                    stroke-width: 0.5px;
                                    commands: "M 25 0 L 25 100 M 50 0 L 50 100 M 75 0 L 75 100 M 0 25 L 100 25 M 0 50 L 100 50 M 0 75 L 100 75";
                                }

                                // Event points (placeholder - would be data-driven)
                                Text {
                                    text: analysis-events-time.length + " events plotted";
                                    font-size: 11px;
                                    color: Pal.cyan;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // Axis labels
                            HorizontalLayout {
                                spacing: 6px;
                                Mon {
                                    text: "0";
                                    font-size: 8px;
                                    color: Pal.lo;
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                }

                                Mon {
                                    text: "26w";
                                    font-size: 8px;
                                    color: Pal.lo;
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                }

                                Mon {
                                    text: "52w";
                                    font-size: 8px;
                                    color: Pal.lo;
                                }
                            }
                        }
                    }

                    // ── Panel 3: Clustering Dendrogram ────────────────────────────
                    Card {
                        vertical-stretch: 1;
                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;
                            Text {
                                text: "CLUSTER HIERARCHY";
                                color: Pal.green;
                                font-size: 14px;
                                font-weight: 900;
                                letter-spacing: 2px;
                                font-family: "Consolas";
                            }

                            Mon {
                                text: "Attack type taxonomy (coherence)";
                                font-size: 9px;
                                color: Pal.lo;
                            }

                            // Dendrogram area
                            Rectangle {
                                vertical-stretch: 1;
                                background: Pal.bg;
                                border-color: Pal.border;
                                border-width: 1px;
                                border-radius: 4px;
                                clip: true;
                                VerticalLayout {
                                    alignment: center;
                                    padding: 12px;
                                    spacing: 8px;
                                    Text {
                                        text: analysis-clusters-names.length + " cluster nodes";
                                        font-size: 13px;
                                        color: Pal.cyan;
                                        horizontal-alignment: center;
                                        font-weight: 900;
                                    }

                                    Rectangle {
                                        height: 8px;
                                    }

                                    // Root cluster display
                                    if analysis-clusters-names.length > 0:
                                        VerticalLayout {
                                        alignment: center;
                                        spacing: 4px;
                                        Text {
                                            text: analysis-clusters-names[0];
                                            font-size: 11px;
                                            color: Pal.hi;
                                            horizontal-alignment: center;
                                            font-weight: 900;
                                        }

                                        Mon {
                                            text: "(n=" + analysis-clusters-sizes[0] + ")";
                                            font-size: 9px;
                                            color: Pal.lo;
                                            horizontal-alignment: center;
                                        }
                                    }
                                    Rectangle {
                                        vertical-stretch: 1;
                                    }

                                    Mon {
                                        text: "↓ Hierarchical splits";
                                        font-size: 9px;
                                        color: Pal.mid;
                                        horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                // ══ RIGHT COLUMN ════════════════════════════════════════════════
                VerticalLayout {
                    spacing: 8px;
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    // ── Panel 2: Pattern Library Heatmap ─────────────────────────
                    Card {
                        vertical-stretch: 1;
                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;
                            Text {
                                text: "PATTERN LIBRARY";
                                color: Pal.orange;
                                font-size: 14px;
                                font-weight: 900;
                                letter-spacing: 2px;
                                font-family: "Consolas";
                            }

                            Mon {
                                text: "Top signatures by feature importance";
                                font-size: 9px;
                                color: Pal.lo;
                            }

                            // Heatmap area
                            Rectangle {
                                vertical-stretch: 1;
                                background: Pal.bg;
                                border-color: Pal.border;
                                border-width: 1px;
                                border-radius: 4px;
                                clip: true;
                                VerticalLayout {
                                    alignment: center;
                                    padding: 12px;
                                    spacing: 8px;
                                    Text {
                                        text: analysis-signatures-names.length + " signatures";
                                        font-size: 14px;
                                        color: Pal.cyan;
                                        font-weight: 900;
                                        horizontal-alignment: center;
                                    }

                                    Rectangle {
                                        height: 4px;
                                    }

                                    // Top signature
                                    if analysis-signatures-names.length > 0:
                                        VerticalLayout {
                                        alignment: center;
                                        spacing: 4px;
                                        Text {
                                            text: "Most Frequent:";
                                            font-size: 10px;
                                            color: Pal.lo;
                                            horizontal-alignment: center;
                                        }

                                        Text {
                                            text: analysis-signatures-names[0];
                                            font-size: 12px;
                                            color: Pal.amber;
                                            horizontal-alignment: center;
                                            font-weight: 900;
                                        }

                                        Mon {
                                            text: "x" + analysis-signatures-counts[0];
                                            font-size: 10px;
                                            color: Pal.mid;
                                            horizontal-alignment: center;
                                        }
                                    }
                                    Rectangle {
                                        vertical-stretch: 1;
                                    }

                                    // Feature importance legend
                                    Text {
                                        text: "Feature Importance";
                                        font-size: 9px;
                                        color: Pal.lo;
                                        horizontal-alignment: center;
                                    }

                                    HorizontalLayout {
                                        alignment: center;
                                        spacing: 10px;
                                        HorizontalLayout {
                                            spacing: 3px;
                                            Rectangle {
                                                width: 8px;
                                                height: 8px;
                                                background: Pal.lo;
                                                border-radius: 1px;
                                            }

                                            Text {
                                                text: "Low";
                                                font-size: 9px;
                                                color: Pal.lo;
                                            }
                                        }

                                        HorizontalLayout {
                                            spacing: 3px;
                                            Rectangle {
                                                width: 8px;
                                                height: 8px;
                                                background: Pal.cyan;
                                                border-radius: 1px;
                                            }

                                            Text {
                                                text: "Med";
                                                font-size: 9px;
                                                color: Pal.lo;
                                            }
                                        }

                                        HorizontalLayout {
                                            spacing: 3px;
                                            Rectangle {
                                                width: 8px;
                                                height: 8px;
                                                background: Pal.amber;
                                                border-radius: 1px;
                                            }

                                            Text {
                                                text: "High";
                                                font-size: 9px;
                                                color: Pal.lo;
                                            }
                                        }

                                        HorizontalLayout {
                                            spacing: 3px;
                                            Rectangle {
                                                width: 8px;
                                                height: 8px;
                                                background: Pal.red;
                                                border-radius: 1px;
                                            }

                                            Text {
                                                text: "Critical";
                                                font-size: 9px;
                                                color: Pal.lo;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ── Panel 4: Correlation Graph ──────────────────────────────
                    Card {
                        vertical-stretch: 1;
                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;
                            Text {
                                text: "CORRELATION NETWORK";
                                color: Pal.purple;
                                font-size: 14px;
                                font-weight: 900;
                                letter-spacing: 2px;
                                font-family: "Consolas";
                            }

                            Mon {
                                text: "Temporal, spectral, spatial relationships";
                                font-size: 9px;
                                color: Pal.lo;
                            }

                            // Network graph area
                            Rectangle {
                                vertical-stretch: 1;
                                background: Pal.bg;
                                border-color: Pal.border;
                                border-width: 1px;
                                border-radius: 4px;
                                clip: true;

                                // Node counts display
                                VerticalLayout {
                                    alignment: center;
                                    padding: 20px;
                                    Text {
                                        text: analysis-events-time.length + " events";
                                        font-size: 18px;
                                        color: Pal.cyan;
                                        font-weight: 900;
                                        horizontal-alignment: center;
                                    }

                                    Rectangle {
                                        height: 4px;
                                    }

                                    Text {
                                        text: analysis-correlations-a.length + " edges";
                                        font-size: 14px;
                                        color: Pal.mid;
                                        horizontal-alignment: center;
                                    }

                                    Rectangle {
                                        height: 12px;
                                    }

                                    // Legend
                                    HorizontalLayout {
                                        alignment: center;
                                        spacing: 10px;
                                        HorizontalLayout {
                                            spacing: 4px;
                                            Rectangle {
                                                width: 6px;
                                                height: 6px;
                                                background: Pal.red;
                                                border-radius: 3px;
                                            }

                                            Text {
                                                text: "Temporal";
                                                font-size: 9px;
                                                color: Pal.lo;
                                            }
                                        }

                                        HorizontalLayout {
                                            spacing: 4px;
                                            Rectangle {
                                                width: 6px;
                                                height: 6px;
                                                background: Pal.cyan;
                                                border-radius: 3px;
                                            }

                                            Text {
                                                text: "Spectral";
                                                font-size: 9px;
                                                color: Pal.lo;
                                            }
                                        }

                                        HorizontalLayout {
                                            spacing: 4px;
                                            Rectangle {
                                                width: 6px;
                                                height: 6px;
                                                background: Pal.green;
                                                border-radius: 3px;
                                            }

                                            Text {
                                                text: "Spatial";
                                                font-size: 9px;
                                                color: Pal.lo;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // ═══════════════════════ CONSOLE TAB ═══════════════════════════════════
        if active-tab == 4: VerticalLayout {
            padding: 12px;
            spacing: 8px;
            vertical-stretch: 1;
            Text {
                text: "SYSTEM CONSOLE";
                color: Pal.amber;
                font-size: 14px;
                font-weight: 900;
                letter-spacing: 2px;
                font-family: "Consolas";
            }

            Card {
                vertical-stretch: 1;
                background: #05060a; // Slightly darker for console feel

                Flickable {
                    viewport-height: log-messages.length * 16px;
                    VerticalLayout {
                        alignment: start;
                        for i in log-messages.length: LogEntry {
                            timestamp: log-timestamps[i];
                            level: log-levels[i];
                            module: log-modules[i];
                            message: log-messages[i];
                        }
                    }
                }
            }

            HorizontalLayout {
                spacing: 12px;
                alignment: end;
                Lbl {
                    text: log-messages.length + " entries in buffer";
                    vertical-alignment: center;
                }
            }
        }

        // ═══════════════════════ CONTROLS TAB ══════════════════════════════════
        if active-tab == 5: HorizontalLayout {
            padding: 12px;
            spacing: 12px;

            // Left Column: Audio & Camera
            VerticalLayout {
                width: 400px;
                spacing: 12px;

                // Audio Device Selection
                Card {
                    height: 140px;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Lbl {
                            text: "AUDIO INPUT DEVICE";
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;
                            Chip {
                                label: "◀ PREV";
                                active: false;
                                accent: Pal.cyan;
                                width: 100px;
                                clicked => {
                                    audio-device-prev();
                                }
                            }

                            Mon {
                                text: audio-device-idx >= 0 && audio-device-idx < audio-device-names.length ? audio-device-names[audio-device-idx] : "No devices";
                                font-size: 14px;
                                horizontal-stretch: 1;
                            }

                            Chip {
                                label: "NEXT ▶";
                                active: false;
                                accent: Pal.cyan;
                                width: 100px;
                                clicked => {
                                    audio-device-next();
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;
                            Lbl {
                                text: "GAIN";
                                width: 60px;
                            }

                            Slider {
                                minimum: 0.0;
                                maximum: 120.0;
                                value: audio-gain-db;
                                changed(v) => {
                                    set-audio-gain(v);
                                }
                            }

                            Mon {
                                text: round(audio-gain-db) + " dB";
                                width: 60px;
                            }
                        }
                    }
                }

                // Camera Configuration
                Card {
                    height: 120px;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        HorizontalLayout {
                            alignment: center;
                            Lbl {
                                text: "CAMERA";
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Toggle {
                                on: camera-active;
                                accent: Pal.green;
                                toggled => {
                                    toggle-camera();
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;
                            Lbl {
                                text: "RESOLUTION:";
                                width: 80px;
                            }

                            Chip {
                                label: "480p";
                                active: camera-resolution == 0;
                                accent: Pal.cyan;
                                clicked => {
                                    set-camera-resolution(0);
                                }
                            }

                            Chip {
                                label: "720p";
                                active: camera-resolution == 1;
                                accent: Pal.cyan;
                                clicked => {
                                    set-camera-resolution(1);
                                }
                            }

                            Chip {
                                label: "1080p";
                                active: camera-resolution == 2;
                                accent: Pal.cyan;
                                clicked => {
                                    set-camera-resolution(2);
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Mon {
                                text: camera-fps + " FPS";
                            }
                        }
                    }
                }
            }

            // Center Column: Frequency Selection
            Card {
                width: 350px;
                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;
                    Lbl {
                        text: "FREQUENCY BAND";
                    }

                    // Band selection chips
                    HorizontalLayout {
                        spacing: 4px;
                        Chip {
                            label: "VLF";
                            active: freq-band-index == 0;
                            accent: Pal.cyan;
                            horizontal-stretch: 1;
                            clicked => {
                                set-freq-band(0);
                            }
                        }

                        Chip {
                            label: "LF";
                            active: freq-band-index == 1;
                            accent: Pal.cyan;
                            horizontal-stretch: 1;
                            clicked => {
                                set-freq-band(1);
                            }
                        }

                        Chip {
                            label: "MF";
                            active: freq-band-index == 2;
                            accent: Pal.cyan;
                            horizontal-stretch: 1;
                            clicked => {
                                set-freq-band(2);
                            }
                        }

                        Chip {
                            label: "HF";
                            active: freq-band-index == 3;
                            accent: Pal.cyan;
                            horizontal-stretch: 1;
                            clicked => {
                                set-freq-band(3);
                            }
                        }

                        Chip {
                            label: "VHF";
                            active: freq-band-index == 4;
                            accent: Pal.cyan;
                            horizontal-stretch: 1;
                            clicked => {
                                set-freq-band(4);
                            }
                        }

                        Chip {
                            label: "UHF";
                            active: freq-band-index == 5;
                            accent: Pal.cyan;
                            horizontal-stretch: 1;
                            clicked => {
                                set-freq-band(5);
                            }
                        }

                        Chip {
                            label: "MANUAL";
                            active: freq-band-index == 6;
                            accent: Pal.amber;
                            horizontal-stretch: 1;
                            clicked => {
                                set-freq-band(6);
                            }
                        }
                    }

                    // Frequency displays
                    VerticalLayout {
                        spacing: 12px;
                        padding-top: 12px;
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;
                            Lbl {
                                text: "BAND:";
                                width: 60px;
                            }

                            Mon {
                                text: freq-band-index == 0 ? "3-30 kHz" : freq-band-index == 1 ? "30-300 kHz" : freq-band-index == 2 ? "300k-3 MHz" : freq-band-index == 3 ? "3-30 MHz" : freq-band-index == 4 ? "30-300 MHz" : freq-band-index == 5 ? "300M-3 GHz" : "MANUAL";
                                color: Pal.cyan;
                                font-size: 14px;
                                horizontal-stretch: 1;
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;
                            Lbl {
                                text: "ACTUAL:";
                                width: 60px;
                            }

                            Mon {
                                text: round(freq-actual-mhz * 100.0) / 100.0 + " MHz";
                                color: Pal.green;
                                font-size: 18px;
                                font-weight: 700;
                                horizontal-stretch: 1;
                            }
                        }

                        if freq-band-index == 6: VerticalLayout {
                            spacing: 8px;
                            Lbl {
                                text: "MANUAL FREQUENCY (MHz)";
                            }

                            TextInput {
                                text: freq-manual-mhz + "";
                                color: Pal.hi;
                                single-line: true;
                                accepted => {
                                    set-freq-manual(self.text.to-float());
                                }
                            }
                        }
                    }
                }
            }

            // Right Column: Parameter Persistence
            Card {
                width: 250px;
                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;
                    Lbl {
                        text: "PARAMETER PRESETS";
                    }

                    Rectangle {
                        height: 1px;
                        background: Pal.border;
                    }

                    Chip {
                        label: "💾 SAVE";
                        active: false;
                        accent: Pal.green;
                        width: 100%;
                        clicked => {
                            save-parameters();
                        }
                    }

                    Chip {
                        label: "📂 LOAD";
                        active: false;
                        accent: Pal.cyan;
                        width: 100%;
                        clicked => {
                            load-parameters();
                        }
                    }

                    Chip {
                        label: "🔄 RESET";
                        active: false;
                        accent: Pal.red;
                        width: 100%;
                        clicked => {
                            reset-parameters();
                        }
                    }

                    Rectangle {
                        height: 1px;
                        background: Pal.border;
                    }

                    Lbl {
                        text: "Settings stored in:";
                        font-size: 8px;
                    }

                    Mon {
                        text: "~/.twister/parameters.json";
                        font-size: 9px;
                        color: Pal.lo;
                    }
                }
            }
        }

        // ═══════════════════════ JOYCON TAB ════════════════════════════════════
        if active-tab == 6: HorizontalLayout {
            padding: 12px;
            spacing: 12px;

            // Left Column: Connection Status & Controls
            VerticalLayout {
                width: 300px;
                spacing: 12px;

                // Connection Status
                Card {
                    height: 100px;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        HorizontalLayout {
                            alignment: center;
                            spacing: 8px;
                            Rectangle {
                                width: 16px;
                                height: 16px;
                                border-radius: 8px;
                                background: joycon-connected ? Pal.green : Pal.red;
                                animate background { duration: 200ms; }
                            }

                            Mon {
                                text: joycon-connected ? "JOY-CON CONNECTED" : "JOY-CON DISCONNECTED";
                                color: joycon-connected ? Pal.green : Pal.red;
                                font-size: 14px;
                                font-weight: 700;
                            }
                        }

                        HorizontalLayout {
                            alignment: center;
                            spacing: 8px;
                            Lbl {
                                text: "GESTURE CONTROL:";
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Toggle {
                                on: joycon-active;
                                accent: Pal.purple;
                                toggled => {
                                    toggle-joycon();
                                }
                            }
                        }
                    }
                }

                // Button States
                Card {
                    height: 200px;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Lbl {
                            text: "BUTTON STATE";
                        }

                        // Button grid (A/B/X/Y)
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;
                            Rectangle {
                                width: 60px;
                                height: 60px;
                                border-radius: 30px;
                                background: joycon-button-y ? Pal.cyan.with-alpha(0.5) : Pal.border;
                                border-color: Pal.cyan;
                                border-width: joycon-button-y ? 3px : 1px;
                                Text {
                                    text: "Y";
                                    color: joycon-button-y ? Pal.hi : Pal.lo;
                                    font-size: 24px;
                                    font-weight: 900;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                width: 120px;
                            }

                            Rectangle {
                                width: 60px;
                                height: 60px;
                                border-radius: 30px;
                                background: joycon-button-x ? Pal.cyan.with-alpha(0.5) : Pal.border;
                                border-color: Pal.cyan;
                                border-width: joycon-button-x ? 3px : 1px;
                                Text {
                                    text: "X";
                                    color: joycon-button-x ? Pal.hi : Pal.lo;
                                    font-size: 24px;
                                    font-weight: 900;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;
                            Rectangle {
                                width: 60px;
                                height: 60px;
                                border-radius: 30px;
                                background: joycon-button-b ? Pal.cyan.with-alpha(0.5) : Pal.border;
                                border-color: Pal.cyan;
                                border-width: joycon-button-b ? 3px : 1px;
                                Text {
                                    text: "B";
                                    color: joycon-button-b ? Pal.hi : Pal.lo;
                                    font-size: 24px;
                                    font-weight: 900;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                width: 120px;
                            }

                            Rectangle {
                                width: 60px;
                                height: 60px;
                                border-radius: 30px;
                                background: joycon-button-a ? Pal.cyan.with-alpha(0.5) : Pal.border;
                                border-color: Pal.cyan;
                                border-width: joycon-button-a ? 3px : 1px;
                                Text {
                                    text: "A";
                                    color: joycon-button-a ? Pal.hi : Pal.lo;
                                    font-size: 24px;
                                    font-weight: 900;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }

            // Center Column: Gyroscope
            Card {
                width: 350px;
                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;
                    Lbl {
                        text: "GYROSCOPE (degrees)";
                    }

                    // Roll
                    VerticalLayout {
                        spacing: 4px;
                        HorizontalLayout {
                            Lbl {
                                text: "ROLL";
                                width: 60px;
                            }

                            HBar {
                                frac: (joycon-gyro-roll + 180.0) / 360.0;
                                bar-color: Pal.cyan;
                                horizontal-stretch: 1;
                            }

                            Mon {
                                text: round(joycon-gyro-roll * 10.0) / 10.0 + "°";
                                width: 70px;
                            }
                        }
                    }

                    // Pitch
                    VerticalLayout {
                        spacing: 4px;
                        HorizontalLayout {
                            Lbl {
                                text: "PITCH";
                                width: 60px;
                            }

                            HBar {
                                frac: (joycon-gyro-pitch + 180.0) / 360.0;
                                bar-color: Pal.green;
                                horizontal-stretch: 1;
                            }

                            Mon {
                                text: round(joycon-gyro-pitch * 10.0) / 10.0 + "°";
                                width: 70px;
                            }
                        }
                    }

                    // Yaw
                    VerticalLayout {
                        spacing: 4px;
                        HorizontalLayout {
                            Lbl {
                                text: "YAW";
                                width: 60px;
                            }

                            HBar {
                                frac: (joycon-gyro-yaw + 180.0) / 360.0;
                                bar-color: Pal.purple;
                                horizontal-stretch: 1;
                            }

                            Mon {
                                text: round(joycon-gyro-yaw * 10.0) / 10.0 + "°";
                                width: 70px;
                            }
                        }
                    }
                }
            }

            // Right Column: Accelerometer & Sticks
            VerticalLayout {
                width: 350px;
                spacing: 12px;

                // Accelerometer
                Card {
                    height: 150px;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Lbl {
                            text: "ACCELEROMETER (G)";
                        }

                        // X axis
                        VerticalLayout {
                            spacing: 4px;
                            HorizontalLayout {
                                Lbl {
                                    text: "X";
                                    width: 40px;
                                }

                                HBar {
                                    frac: (joycon-accel-x + 2.0) / 4.0;
                                    bar-color: Pal.cyan;
                                    horizontal-stretch: 1;
                                }

                                Mon {
                                    text: round(joycon-accel-x * 100.0) / 100.0;
                                    width: 50px;
                                }
                            }
                        }

                        // Y axis
                        VerticalLayout {
                            spacing: 4px;
                            HorizontalLayout {
                                Lbl {
                                    text: "Y";
                                    width: 40px;
                                }

                                HBar {
                                    frac: (joycon-accel-y + 2.0) / 4.0;
                                    bar-color: Pal.green;
                                    horizontal-stretch: 1;
                                }

                                Mon {
                                    text: round(joycon-accel-y * 100.0) / 100.0;
                                    width: 50px;
                                }
                            }
                        }

                        // Z axis
                        VerticalLayout {
                            spacing: 4px;
                            HorizontalLayout {
                                Lbl {
                                    text: "Z";
                                    width: 40px;
                                }

                                HBar {
                                    frac: (joycon-accel-z + 2.0) / 4.0;
                                    bar-color: Pal.purple;
                                    horizontal-stretch: 1;
                                }

                                Mon {
                                    text: round(joycon-accel-z * 100.0) / 100.0;
                                    width: 50px;
                                }
                            }
                        }
                    }
                }

                // Triggers
                Card {
                    height: 100px;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Lbl {
                            text: "TRIGGERS";
                        }

                        // L Trigger
                        VerticalLayout {
                            spacing: 4px;
                            HorizontalLayout {
                                Lbl {
                                    text: "L";
                                    width: 40px;
                                }

                                HBar {
                                    frac: joycon-trigger-l;
                                    bar-color: Pal.amber;
                                    horizontal-stretch: 1;
                                }

                                Mon {
                                    text: round(joycon-trigger-l * 100.0) + "%";
                                    width: 50px;
                                }
                            }
                        }

                        // R Trigger
                        VerticalLayout {
                            spacing: 4px;
                            HorizontalLayout {
                                Lbl {
                                    text: "R";
                                    width: 40px;
                                }

                                HBar {
                                    frac: joycon-trigger-r;
                                    bar-color: Pal.orange;
                                    horizontal-stretch: 1;
                                }

                                Mon {
                                    text: round(joycon-trigger-r * 100.0) + "%";
                                    width: 50px;
                                }
                            }
                        }
                    }
                }
            }

            // Far Right: Gesture Mapping Reference
            Card {
                width: 280px;
                VerticalLayout {
                    padding: 12px;
                    spacing: 6px;
                    Lbl {
                        text: "GESTURE MAPPINGS";
                    }

                    Rectangle {
                        height: 1px;
                        background: Pal.border;
                    }

                    // Mapping reference list
                    VerticalLayout {
                        spacing: 4px;
                        Text {
                            text: "🎮 Roll → Viewport Rotation";
                            color: Pal.mid;
                            font-size: 10px;
                        }

                        Text {
                            text: "🎮 Pitch/Yaw → Heterodyne Steering";
                            color: Pal.mid;
                            font-size: 10px;
                        }

                        Text {
                            text: "🕹️ L Stick → Fine AZ/EL Control";
                            color: Pal.mid;
                            font-size: 10px;
                        }

                        Text {
                            text: "🕹️ R Stick → Frequency Modulation";
                            color: Pal.mid;
                            font-size: 10px;
                        }

                        Text {
                            text: "📐 Accelerometer → Heterodyne Strength";
                            color: Pal.mid;
                            font-size: 10px;
                        }

                        Text {
                            text: "🔴 R Trigger → Carrier Freq Offset";
                            color: Pal.mid;
                            font-size: 10px;
                        }

                        Text {
                            text: "🔘 A → Toggle PDM";
                            color: Pal.cyan;
                            font-size: 10px;
                            font-weight: 700;
                        }

                        Text {
                            text: "🔘 B → Toggle ANC";
                            color: Pal.green;
                            font-size: 10px;
                            font-weight: 700;
                        }

                        Text {
                            text: "🔘 X → Toggle Auto-Tune";
                            color: Pal.purple;
                            font-size: 10px;
                            font-weight: 700;
                        }

                        Text {
                            text: "🔘 Y → Toggle Recording";
                            color: Pal.amber;
                            font-size: 10px;
                            font-weight: 700;
                        }
                    }
                }
            }
        }
    }
}

// Dummy addition for now to ensure compilation doesn't fail based on the `ChatMessage` and `CopilotPanel` imports.
// Note: We'd need to properly place `CopilotPanel` inside the main `AppWindow` in a real scenario.
