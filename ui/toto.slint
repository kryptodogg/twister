import { Button, CheckBox, SpinBox, Slider, GroupBox, LineEdit, StandardListView, Switch } from "std-widgets.slint";

export global Colors {
    out property <color> surface-dim: #0F111A;
    out property <color> surface-container: #1A1D2B;
    out property <color> surface-container-high: #22253A;
    out property <color> surface-container-highest: #292C3F;
    out property <color> primary: #00E5C8;
    out property <color> secondary: #A855F7;
    out property <color> tertiary: #F59E0B;
    out property <color> error: #FF5449;
    out property <color> on-surface: #E1E3F0;
    out property <color> on-surface-variant: #9CA3AF;
    out property <color> outline: rgba(255, 255, 255, 12%);
    out property <color> outline-variant: rgba(255, 255, 255, 6%);

    // Harmonic Palette (C through B)
    out property <color> harm-0: #FF1A1A;
    out property <color> harm-1: #FF6600;
    out property <color> harm-2: #FFAA00;
    out property <color> harm-3: #E5E500;
    out property <color> harm-4: #66E620;
    out property <color> harm-5: #9910FF;
    out property <color> harm-6: #6600FF;
    out property <color> harm-7: #0099FF;
    out property <color> harm-8: #00E5CC;
    out property <color> harm-9: #1ADD4D;
    out property <color> harm-10: #B3F21A;
    out property <color> harm-11: #F21AB3;
}

export global TotoEngine {
    in property <string> audio-status: "DISCONNECTED";
    in property <string> rf-status: "DISCONNECTED";
    in property <string> optical-status: "DISCONNECTED";
    in property <float> anomaly-score: 0.0;
    in property <float> drive: 0.0;
    in property <float> fold: 0.0;
    in property <float> asym: 0.0;
    in property <float> dominant-freq-hz: 0.0;
    in property <string> wave-path: "M 0 50";

    // 12 Harmonic Paths for BSS Visualization
    in property <string> path-c: "M 0 50";
    in property <string> path-cs: "M 0 50";
    in property <string> path-d: "M 0 50";
    in property <string> path-ds: "M 0 50";
    in property <string> path-e: "M 0 50";
    in property <string> path-f: "M 0 50";
    in property <string> path-fs: "M 0 50";
    in property <string> path-g: "M 0 50";
    in property <string> path-gs: "M 0 50";
    in property <string> path-a: "M 0 50";
    in property <string> path-as: "M 0 50";
    in property <string> path-b: "M 0 50";

    in property <color> wave-color: Colors.primary;
    in-out property <bool> always-learning: true;
    in-out property <bool> metrics-expanded: false;
}

component StatusBadge {
    in property <string> label;
    in property <string> status;
    property <color> status-color:
        status == "LIVE" ? Colors.primary :
        status == "HW FAULT" ? Colors.error :
        Colors.on-surface-variant;
    Rectangle {
        background: Colors.surface-container-high;
        border-radius: 4px;
        border-width: 1px;
        border-color: status-color;
        height: 24px;
        HorizontalLayout {
            padding-left: 8px;
            padding-right: 8px;
            spacing: 4px;
            Text { text: label + ":"; color: Colors.on-surface-variant; font-size: 10px; vertical-alignment: center; }
            Text { text: status; color: status-color; font-size: 10px; font-weight: 700; vertical-alignment: center; }
        }
    }
}

export component TotoCard inherits Window {
    title: "Toto HUD";
    background: Colors.surface-dim;
    property <length> unit-size: 16px;

    // Golden Ratio width/height
    width: 600px;
    height: 370px;

    VerticalLayout {
        padding: unit-size;
        spacing: unit-size * 0.5;
        HorizontalLayout {
            height: unit-size * 3;
            spacing: unit-size;
            VerticalLayout {
                spacing: unit-size * 0.25;
                alignment: center;
                Text { text: "ANOMALY SCORE"; color: Colors.on-surface-variant; font-size: unit-size * 0.6; font-weight: 700; }
                Text { text: round(TotoEngine.anomaly-score * 1000) / 1000; color: Colors.on-surface; font-size: unit-size * 1.5; font-family: "JetBrains Mono"; }
            }
            Rectangle { width: 1px; background: Colors.outline-variant; }
            HorizontalLayout {
                spacing: unit-size * 0.5;
                alignment: center;
                StatusBadge { label: "AUDIO"; status: TotoEngine.audio-status; }
                StatusBadge { label: "RF"; status: TotoEngine.rf-status; }
                StatusBadge { label: "OPTICAL"; status: TotoEngine.optical-status; }
            }
        }

        // Universal Rainbow Harmonic Smear (BSS)
        Rectangle {
            background: Colors.surface-container;
            border-radius: unit-size * 0.5;
            border-width: 1px;
            border-color: Colors.outline;
            height: 180px;
            clip: true;

            // The 12 overlapping signal layers
            Path { commands: TotoEngine.path-c; stroke: Colors.harm-0; stroke-width: 1.5px; opacity: 0.4; }
            Path { commands: TotoEngine.path-cs; stroke: Colors.harm-1; stroke-width: 1.5px; opacity: 0.4; }
            Path { commands: TotoEngine.path-d; stroke: Colors.harm-2; stroke-width: 1.5px; opacity: 0.4; }
            Path { commands: TotoEngine.path-ds; stroke: Colors.harm-3; stroke-width: 1.5px; opacity: 0.4; }
            Path { commands: TotoEngine.path-e; stroke: Colors.harm-4; stroke-width: 1.5px; opacity: 0.4; }
            Path { commands: TotoEngine.path-f; stroke: Colors.harm-5; stroke-width: 1.5px; opacity: 0.4; }
            Path { commands: TotoEngine.path-fs; stroke: Colors.harm-6; stroke-width: 2.0px; opacity: 0.8; }
            Path { commands: TotoEngine.path-g; stroke: Colors.harm-7; stroke-width: 1.5px; opacity: 0.4; }
            Path { commands: TotoEngine.path-gs; stroke: Colors.harm-8; stroke-width: 1.5px; opacity: 0.4; }
            Path { commands: TotoEngine.path-a; stroke: Colors.harm-9; stroke-width: 1.5px; opacity: 0.4; }
            Path { commands: TotoEngine.path-as; stroke: Colors.harm-10; stroke-width: 1.5px; opacity: 0.4; }
            Path { commands: TotoEngine.path-b; stroke: Colors.harm-11; stroke-width: 1.5px; opacity: 0.4; }

            Text { text: "ML DERIVED"; color: Colors.secondary; font-size: unit-size * 0.5; font-weight: 700; x: parent.width - self.width - 8px; y: 8px; }
        }

        HorizontalLayout {
            spacing: unit-size * 0.75;
            VerticalLayout {
                spacing: unit-size * 0.25;
                Text { text: "DRIVE"; color: Colors.on-surface-variant; font-size: unit-size * 0.6; font-weight: 700; }
                Text { text: round(TotoEngine.drive * 1000) / 1000; color: Colors.on-surface; font-size: unit-size; font-family: "JetBrains Mono"; }
                Rectangle { height: 4px; background: Colors.surface-container-highest; Rectangle { x: 0; width: TotoEngine.drive * parent.width; background: Colors.primary; } }
            }
            VerticalLayout {
                spacing: unit-size * 0.25;
                Text { text: "FOLD"; color: Colors.on-surface-variant; font-size: unit-size * 0.6; font-weight: 700; }
                Text { text: round(TotoEngine.fold * 1000) / 1000; color: Colors.on-surface; font-size: unit-size; font-family: "JetBrains Mono"; }
                Rectangle { height: 4px; background: Colors.surface-container-highest; Rectangle { x: 0; width: TotoEngine.fold * parent.width; background: Colors.secondary; } }
            }
            VerticalLayout {
                spacing: unit-size * 0.25;
                Text { text: "ASYM"; color: Colors.on-surface-variant; font-size: unit-size * 0.6; font-weight: 700; }
                Text { text: round(TotoEngine.asym * 1000) / 1000; color: Colors.on-surface; font-size: unit-size; font-family: "JetBrains Mono"; }
                Rectangle { height: 4px; background: Colors.surface-container-highest; Rectangle { x: 0; width: (TotoEngine.asym + 1.0) * 0.5 * parent.width; background: Colors.tertiary; } }
            }
        }
    }
}
