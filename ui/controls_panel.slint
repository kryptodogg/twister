import { HorizontalBox, VerticalBox, Slider, Button, CheckBox, ComboBox, LineEdit } from "std-widgets.slint";

export global AppControls {
    in-out property <string> mic-name;
    in-out property <float> mic-sample-rate-khz;
    in-out property <float> gain-multiplier;
    in-out property <float> gain-db;
    in-out property <float> input-level-db;
    in-out property <bool> agc-enabled;
    in-out property <float> agc-target-db;
    in-out property <int> freq-band-index;
    in-out property <float> freq-actual-hz;
    in-out property <string> freq-manual-hz-string;
    in-out property <int> camera-resolution-index;
    in-out property <float> camera-fps;
    in-out property <bool> camera-enabled;

    callback mic-prev();
    callback mic-next();
    callback set-freq-band(string);
    callback set-camera-resolution(string);
    callback save-parameters();
    callback load-parameters();
    callback reset-parameters();
}

export component ControlsPanel inherits Rectangle {
    background: #111;

    VerticalBox {
        spacing: 20px;
        padding: 20px;

        // MIC SELECTION
        HorizontalBox {
            Text { text: "Audio Input:"; min-width: 150px; color: white; }
            Button { text: "<"; width: 40px; clicked => { AppControls.mic-prev(); } }
            Rectangle {
                background: #222;
                border-color: #444;
                border-width: 1px;
                border-radius: 4px;
                min-width: 250px;
                HorizontalBox {
                    padding: 8px;
                    Text { text: AppControls.mic-name; color: #0f0; }
                }
            }
            Button { text: ">"; width: 40px; clicked => { AppControls.mic-next(); } }
            Text { text: "\{AppControls.mic-sample-rate-khz} kHz"; color: #888; }
        }

        // GAIN CONTROL
        HorizontalBox {
            Text { text: "Gain:"; min-width: 150px; color: white; }
            Slider {
                width: 300px;
                minimum: 0.0;
                maximum: 1.0;
                value <=> AppControls.gain-multiplier;
            }
            Text {
                text: "\{round(AppControls.gain-db)} dB";
                min-width: 60px;
                color: AppControls.input-level-db > -20.0 ? #f00 : #0f0;
            }
            Text { text: "Input: \{round(AppControls.input-level-db)} dB"; color: #888; min-width: 150px; }
        }

        HorizontalBox {
            spacing: 10px;
            padding-left: 150px;
            CheckBox { checked <=> AppControls.agc-enabled; text: "Auto Gain Control (AGC)"; }
            Text {
                text: "Target: \{round(AppControls.agc-target-db)} dB";
                color: #888;
                visible: AppControls.agc-enabled;
            }
        }

        // FREQUENCY SELECTION
        HorizontalBox {
            Text { text: "Frequency Band:"; min-width: 150px; color: white; }
            ComboBox {
                model: ["VLF (50 Hz)", "LF (1 kHz)", "MF (100 kHz)", "HF (10 MHz)", "VHF (100 MHz)", "UHF (1 GHz)", "Manual"];
                current-index <=> AppControls.freq-band-index;
                selected(index) => { AppControls.set-freq-band(index); }
            }
            Text { text: "\{round(AppControls.freq-actual-hz)} Hz"; color: #0f0; min-width: 150px; }
        }

        // Manual Frequency Entry
        HorizontalBox {
            visible: AppControls.freq-band-index == 6;
            padding-left: 150px;
            spacing: 10px;
            Text { text: "Enter frequency (Hz):"; color: white; }
            LineEdit {
                text <=> AppControls.freq-manual-hz-string;
                placeholder-text: "e.g., 145500000";
                width: 200px;
            }
        }

        // CAMERA RESOLUTION
        HorizontalBox {
            Text { text: "Camera:"; min-width: 150px; color: white; }
            ComboBox {
                model: ["480p (640x480)", "720p (1280x720)", "1080p (1920x1080)"];
                current-index: AppControls.camera-resolution-index;
                selected(index) => { AppControls.set-camera-resolution(index); }
            }
            Text { text: "\{round(AppControls.camera-fps)} FPS"; color: #0f0; min-width: 100px; }
            CheckBox { checked <=> AppControls.camera-enabled; text: "Active"; }
        }

        // PARAMETER PERSISTENCE BUTTONS
        HorizontalBox {
            padding-left: 150px;
            spacing: 10px;
            Button { text: "Save Preset"; clicked => { AppControls.save-parameters(); } }
            Button { text: "Load Preset"; clicked => { AppControls.load-parameters(); } }
            Button { text: "Reset to Default"; clicked => { AppControls.reset-parameters(); } }
        }
    }
}
