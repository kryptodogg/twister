import { VerticalBox, HorizontalBox, Button, Switch } from "std-widgets.slint";

export global PS5Status {
    in-out property <bool> rumble_enabled: true;
    in-out property <bool> test_button_pressed: false;
    in-out property <float> touch_x;
    in-out property <float> touch_y;
    in-out property <float> left_trigger_force;
    in-out property <float> right_trigger_force;
    in-out property <float> left_vibration_intensity;
    in-out property <float> right_vibration_intensity;
    in-out property <string> battery;

    callback rumble_toggled(bool);
    callback test_toggled(bool);
}

export component HapticTestButton inherits Rectangle {
    in property <string> label: "TEST RESONANCE";

    Rectangle {
        background: ta.pressed ? #b0f : #0cf3;
        border-color: #0cf;
        border-width: 1px;
        height: 40px;
        border-radius: 4px;

        Text {
            text: label;
            color: #0cf;
            font-family: "monospace";
            font-size: 14px;
            font-weight: 700;
        }

        ta := TouchArea {
            pointer-event(event) => {
                if (event.button == PointerEventButton.left) {
                    PS5Status.test_toggled(event.kind == PointerEventKind.down);
                    PS5Status.test_button_pressed = event.kind == PointerEventKind.down;
                }
            }
        }
    }
}

export component ValueBar inherits Rectangle {
    in property <float> value: 0.0; // 0.0 to 1.0
    in property <string> label;

    VerticalBox {
        padding: 0;
        spacing: 5px;
        alignment: start;

        Rectangle {
            width: 40px;
            height: 150px;
            border-color: #0cf;
            border-width: 1px;
            background: #0000;

            Rectangle {
                y: parent.height - self.height;
                width: parent.width;
                height: parent.height * root.value;
                background: @linear-gradient(180deg, #0cf, #00f);
                opacity: 0.8;
            }
        }
        Text {
            text: root.label;
            color: #ccc;
            font-family: "monospace";
            font-size: 10px;
            horizontal-alignment: center;
        }
    }
}

export component RingMeter inherits Rectangle {
    in property <float> value: 0.0; // 0.0 to 1.0
    in property <string> label;
    in property <color> ring_color: #0cf;

    VerticalBox {
        padding: 0;
        spacing: 10px;
        alignment: center;

        Rectangle {
            width: 80px;
            height: 80px;
            border-radius: 40px;
            border-color: root.ring_color;
            border-width: 2px;
            background: #0000;

            // Inner fill visualization
            Rectangle {
                width: parent.width * 0.8;
                height: parent.height * 0.8;
                border-radius: self.width / 2;
                background: root.ring_color;
                opacity: 0.2 + (root.value * 0.6);
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }

            Text {
                text: round(root.value * 100) + "%";
                color: #fff;
                font-family: "monospace";
                font-size: 14px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            text: root.label;
            color: #ccc;
            font-family: "monospace";
            font-size: 10px;
            horizontal-alignment: center;
        }
    }
}

export component PS5DeckApplet inherits Window {
    title: "PS5 Haptic Command Deck";
    width: 600px;
    height: 400px;
    background: #050505aa;
    always-on-top: true;

    VerticalBox {
        padding: 20px;
        spacing: 15px;

        HorizontalBox {
            alignment: space-between;
            VerticalBox {
                padding: 0;
                spacing: 2px;
                Text { text: "PS5 HAPTIC COMMAND DECK"; color: #0cf; font-weight: 800; font-family: "monospace"; font-size: 18px; }
                Text { text: "DualSense v0.6.0"; color: #666; font-family: "monospace"; font-size: 12px; }
            }
            Text { text: "🔋 " + PS5Status.battery + " - Active (BT)"; color: #ccc; font-family: "monospace"; font-size: 12px; }
        }

        HorizontalBox {
            spacing: 30px;

            // Left Column: Haptics & Touchpad
            VerticalBox {
                spacing: 20px;

                Text { text: "HAPTIC RESONANCE"; color: #ccc; font-family: "monospace"; font-size: 14px; }

                HorizontalBox {
                    spacing: 20px;
                    RingMeter { value: PS5Status.left_vibration_intensity; label: "Left Voice Coil"; ring_color: #0cf; }
                    RingMeter { value: PS5Status.right_vibration_intensity; label: "Right Voice Coil"; ring_color: #b0f; }
                }

                Text { text: "FIELD NAVIGATION"; color: #ccc; font-family: "monospace"; font-size: 14px; }

                // Touchpad visualization
                Rectangle {
                    width: 250px;
                    height: 100px;
                    border-color: #0cf;
                    border-width: 1px;
                    background: #0000;

                    // Grid lines (simplified)
                    Rectangle { width: 1px; height: parent.height; background: #0cf5; x: parent.width / 2; }
                    Rectangle { width: parent.width; height: 1px; background: #0cf5; y: parent.height / 2; }

                    // Cursor
                    Rectangle {
                        width: 4px;
                        height: 4px;
                        border-radius: 2px;
                        background: #fff;
                        x: min(max((PS5Status.touch_x / 1920.0) * parent.width - 2px, 0px), parent.width - 4px);
                        y: min(max((PS5Status.touch_y / 1080.0) * parent.height - 2px, 0px), parent.height - 4px);
                    }

                    Text {
                        text: "X: " + round(PS5Status.touch_x) + "\nY: " + round(PS5Status.touch_y);
                        color: #0cf;
                        font-family: "monospace";
                        font-size: 10px;
                        x: min(max((PS5Status.touch_x / 1920.0) * parent.width + 5px, 0px), parent.width - 40px);
                        y: min(max((PS5Status.touch_y / 1080.0) * parent.height + 5px, 0px), parent.height - 20px);
                    }
                }
            }

            // Right Column: Triggers & Controls
            VerticalBox {
                spacing: 20px;

                Text { text: "ADAPTIVE TRIGGERS"; color: #ccc; font-family: "monospace"; font-size: 14px; }

                HorizontalBox {
                    spacing: 30px;
                    ValueBar { value: PS5Status.left_trigger_force; label: "L2 Force Feedback"; }
                    ValueBar { value: PS5Status.right_trigger_force; label: "R2 Dynamic Gain"; }
                }

                Text { text: "CONTROLS"; color: #ccc; font-family: "monospace"; font-size: 14px; }

                HorizontalBox {
                    spacing: 15px;
                    Switch {
                        checked <=> PS5Status.rumble_enabled;
                        toggled => { PS5Status.rumble_toggled(self.checked); }
                    }
                    Text { text: "SIGNAL RUMBLE"; color: #fff; font-family: "monospace"; vertical-alignment: center; }
                }

                HapticTestButton {
                    label: "TEST RESONANCE";
                }
            }
        }
    }
}
