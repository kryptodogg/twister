// MAMBA BRAIN UNIFIED FIELD INFERENCE VISUALIZATION
// Material Design Refactor: Responsive layouts, animated particles, Material components
// Pattern Origin: joycon_wand.slint + Material Slint design system

import { VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";
import { Standards, IconButton, ForensicPalette, ForensicMaterials } from "../standards.slint";

export global MambaBrainStatus {
    // Scalar latent metrics from 128D → 4D projection
    in-out property <float> frequency-tracker: 0.0;
    in-out property <float> harmonic-smear: 0.0;
    in-out property <float> anomaly-score: 0.0;
    in-out property <float> material-confidence: 0.0;

    // Particle positions (12 clusters) - format: "x,y,energy|x,y,energy|..."
    in-out property <string> particle-positions: "";

    // Pre-parsed particle data (12 particles × 3 values = 36 floats)
    // These are populated by parsing particle-positions string in Rust
    in-out property <[float]> particle-data: [
        0.0, 0.0, 0.5,  // Particle 0
        0.0, 0.0, 0.5,  // Particle 1
        0.0, 0.0, 0.5,  // Particle 2
        0.0, 0.0, 0.5,  // Particle 3
        0.0, 0.0, 0.5,  // Particle 4
        0.0, 0.0, 0.5,  // Particle 5
        0.0, 0.0, 0.5,  // Particle 6
        0.0, 0.0, 0.5,  // Particle 7
        0.0, 0.0, 0.5,  // Particle 8
        0.0, 0.0, 0.5,  // Particle 9
        0.0, 0.0, 0.5,  // Particle 10
        0.0, 0.0, 0.5,  // Particle 11
    ];

    // Inference status
    in-out property <bool> inference-active: false;
    in-out property <int> inference-fps: 60;

    // UI state
    in-out property <bool> metrics-panel-visible: true;
}

// Helper component: Particle dot with energy-based opacity
component ParticleDot inherits Rectangle {
    in property <float> energy: 0.5;      // [0, 1]
    in property <color> dot-color: #00ffff;

    width: 10px;
    height: 10px;
    border-radius: 5px;
    background: dot-color;
    opacity: 0.2 + 0.8 * energy;

    // Smooth opacity animation
    animate opacity { duration: 100ms; easing: ease-in-out; }
}

// Helper component: Metric card with responsive sizing
component MetricCard inherits Rectangle {
    in property <string> label: "";
    in property <float> value: 0.0;
    in property <string> formatted-value: "";
    in property <color> accent-color: ForensicPalette.ag_cyan;

    background: ForensicMaterials.surface_panel;
    border-color: accent-color;
    border-width: 1px;
    border-radius: 6px;
    horizontal-stretch: 1;

    VerticalBox {
        padding: 12px;
        spacing: 4px;

        Text {
            text: label;
            color: accent-color;
            font-weight: 700;
            font-size: 11px;
            font-family: "monospace";
        }
        Text {
            text: formatted-value;
            color: accent-color;
            font-family: "monospace";
            font-size: 16px;
            font-weight: 700;
        }
    }
}

export component MambaBrainApplet inherits Window {
    title: "AG-Brain: Unified Field Inference";
    // Resizable window - no fixed dimensions
    width: 1200px;
    height: 700px;
    background: @linear-gradient(180deg, #11111166 0%, #000000bb 100%);

    VerticalBox {
        spacing: 12px;
        padding: 16px;

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // HEADER: Inference Status with Material Controls
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        Rectangle {
            background: ForensicMaterials.surface_panel;
            border-radius: 8px;
            border-color: ForensicPalette.ag_cyan;
            border-width: 1px;
            height: 60px;

            HorizontalBox {
                padding: 12px;
                spacing: 16px;
                alignment: space-between;

                // Left side: Status indicator
                VerticalBox {
                    spacing: 2px;

                    Text {
                        text: MambaBrainStatus.inference-active ? "🧠 MAMBA BRAIN ACTIVE" : "🧠 STANDBY";
                        color: MambaBrainStatus.inference-active ? ForensicPalette.ag_cyan : #ff8800;
                        font-weight: 800;
                        font-size: 13px;
                        font-family: "monospace";
                    }
                    Text {
                        text: "Unified Field Inference @ " + MambaBrainStatus.inference-fps + " FPS";
                        color: #aaa;
                        font-family: "monospace";
                        font-size: 9px;
                    }
                }

                // Right side: Quick metrics + toggle button
                HorizontalBox {
                    spacing: 20px;
                    alignment: end;

                    // Quick metric displays
                    HorizontalBox {
                        spacing: 24px;

                        VerticalBox {
                            spacing: 1px;
                            Text { text: "Anomaly"; color: #888; font-size: 8px; font-family: "monospace"; }
                            Text {
                                text: round(MambaBrainStatus.anomaly-score * 1000.0) / 1000.0;
                                color: MambaBrainStatus.anomaly-score > 0.5 ? ForensicPalette.ag_red : ForensicPalette.ag_cyan;
                                font-family: "monospace";
                                font-weight: 700;
                                font-size: 11px;
                            }
                        }

                        VerticalBox {
                            spacing: 1px;
                            Text { text: "Confidence"; color: #888; font-size: 8px; font-family: "monospace"; }
                            Text {
                                text: round(MambaBrainStatus.material-confidence * 100.0) + "%";
                                color: ForensicPalette.ag_cyan;
                                font-family: "monospace";
                                font-weight: 700;
                                font-size: 11px;
                            }
                        }
                    }

                    // Material Design toggle button (gear icon)
                    Rectangle {
                        width: 36px;
                        height: 36px;
                        border-radius: 4px;
                        background: transparent;
                        border-width: 1px;
                        border-color: ForensicPalette.ag_cyan;

                        Text {
                            text: MambaBrainStatus.metrics-panel-visible ? "⚙️" : "📊";
                            font-size: 18px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: 100%;
                            height: 100%;
                        }

                        TouchArea {
                            clicked => {
                                MambaBrainStatus.metrics-panel-visible = !MambaBrainStatus.metrics-panel-visible;
                            }
                        }
                    }
                }
            }
        }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // MAIN CONTENT: Particle visualization + optional metrics
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        HorizontalBox {
            spacing: 12px;
            horizontal-stretch: 1;
            vertical-stretch: 1;

            // Left: Particle cloud visualization
            Rectangle {
                background: ForensicMaterials.surface_panel;
                border-color: ForensicPalette.ag_violet;
                border-width: 2px;
                border-radius: 8px;
                horizontal-stretch: 1;

                VerticalBox {
                    padding: 12px;
                    spacing: 8px;

                    Text {
                        text: "128D Latent → 2D PCA | " + MambaBrainStatus.inference-fps + " Hz update";
                        color: ForensicPalette.ag_violet;
                        font-weight: 700;
                        font-size: 10px;
                        font-family: "monospace";
                    }

                    // Particle visualization canvas
                    Rectangle {
                        width: 100%;
                        height: 100%;
                        background: @linear-gradient(135deg, #0a0a0a 0%, #1a0a1a 100%);
                        border-radius: 4px;

                        HorizontalBox {
                            padding: 20px;
                            spacing: 15px;

                            // Left column: Particle dots (6 particles)
                            VerticalBox {
                                spacing: 12px;
                                ParticleDot { dot-color: #ff0000; energy: MambaBrainStatus.particle-data[2]; }
                                ParticleDot { dot-color: #00ffff; energy: MambaBrainStatus.particle-data[5]; }
                                ParticleDot { dot-color: #ff00ff; energy: MambaBrainStatus.particle-data[8]; }
                                ParticleDot { dot-color: #ffff00; energy: MambaBrainStatus.particle-data[11]; }
                                ParticleDot { dot-color: #00ff00; energy: MambaBrainStatus.particle-data[14]; }
                                ParticleDot { dot-color: #ff6600; energy: MambaBrainStatus.particle-data[17]; }
                            }

                            // Center: Energy visualization (animated bars)
                            VerticalBox {
                                spacing: 8px;
                                horizontal-stretch: 1;

                                Rectangle {
                                    height: 4px;
                                    width: 100%;
                                    background: #1a1a2a;
                                    border-radius: 2px;
                                    Rectangle {
                                        height: 100%;
                                        background: #ff0000;
                                        width: max(10px, parent.width * (0.4 + MambaBrainStatus.frequency-tracker * 0.6));
                                        animate width { duration: 100ms; easing: ease-in-out; }
                                    }
                                }
                                Rectangle {
                                    height: 4px;
                                    width: 100%;
                                    background: #1a1a2a;
                                    border-radius: 2px;
                                    Rectangle {
                                        height: 100%;
                                        background: #00ffff;
                                        width: max(10px, parent.width * (0.3 + MambaBrainStatus.harmonic-smear * 0.7));
                                        animate width { duration: 100ms; easing: ease-in-out; }
                                    }
                                }
                                Rectangle {
                                    height: 4px;
                                    width: 100%;
                                    background: #1a1a2a;
                                    border-radius: 2px;
                                    Rectangle {
                                        height: 100%;
                                        background: #ff00ff;
                                        width: max(10px, parent.width * (0.2 + MambaBrainStatus.anomaly-score * 0.8));
                                        animate width { duration: 100ms; easing: ease-in-out; }
                                    }
                                }
                                Rectangle {
                                    height: 4px;
                                    width: 100%;
                                    background: #1a1a2a;
                                    border-radius: 2px;
                                    Rectangle {
                                        height: 100%;
                                        background: #ffff00;
                                        width: max(10px, parent.width * (0.35 + MambaBrainStatus.material-confidence * 0.65));
                                        animate width { duration: 100ms; easing: ease-in-out; }
                                    }
                                }
                            }

                            // Right column: Remaining particles (6 particles)
                            VerticalBox {
                                spacing: 12px;
                                ParticleDot { dot-color: #0099ff; energy: MambaBrainStatus.particle-data[20]; }
                                ParticleDot { dot-color: #ff00ff; energy: MambaBrainStatus.particle-data[23]; }
                                ParticleDot { dot-color: #00ff00; energy: MambaBrainStatus.particle-data[26]; }
                                ParticleDot { dot-color: #ff8800; energy: MambaBrainStatus.particle-data[29]; }
                                ParticleDot { dot-color: #ffff00; energy: MambaBrainStatus.particle-data[32]; }
                                ParticleDot { dot-color: #0099ff; energy: MambaBrainStatus.particle-data[35]; }
                            }
                        }
                    }
                }
            }

            // Right side: Metrics panel (togglable via gear icon)
            Rectangle {
                width: MambaBrainStatus.metrics-panel-visible ? 240px : 0px;
                height: 100%;
                background: ForensicMaterials.surface_panel;
                border-color: ForensicPalette.ag_cyan;
                border-width: 1px;
                border-radius: 8px;
                opacity: MambaBrainStatus.metrics-panel-visible ? 1.0 : 0.0;

                animate width { duration: 200ms; easing: ease-in-out; }
                animate opacity { duration: 200ms; }

                VerticalBox {
                    padding: 12px;
                    spacing: 10px;

                    Text {
                        text: "METRICS";
                        color: ForensicPalette.ag_cyan;
                        font-weight: 700;
                        font-size: 10px;
                        font-family: "monospace";
                    }

                    // Frequency metric card
                    MetricCard {
                        label: "📡 FREQUENCY";
                        formatted-value: round(MambaBrainStatus.frequency-tracker * 100.0) + "%";
                        accent-color: ForensicPalette.ag_red;
                    }

                    // Harmonic metric card
                    MetricCard {
                        label: "🌊 HARMONIC";
                        formatted-value: round(MambaBrainStatus.harmonic-smear * 1000.0) / 1000.0;
                        accent-color: ForensicPalette.hue-e;
                    }

                    // Anomaly metric card
                    MetricCard {
                        label: "⚠️ ANOMALY";
                        formatted-value: round(MambaBrainStatus.anomaly-score * 1000.0) / 1000.0;
                        accent-color: ForensicPalette.ag_violet;
                    }

                    // Confidence metric card
                    MetricCard {
                        label: "🎯 CONFIDENCE";
                        formatted-value: round(MambaBrainStatus.material-confidence * 1000.0) / 1000.0;
                        accent-color: ForensicPalette.ag_cyan;
                    }

                    // Status bar
                    Rectangle {
                        height: 24px;
                        background: transparent;
                        border-color: #333;
                        border-width: 1px;
                        border-radius: 4px;

                        Text {
                            text: MambaBrainStatus.inference-active ? "✓ Running" : "⊘ Waiting";
                            color: MambaBrainStatus.inference-active ? #0f0 : #f80;
                            font-family: "monospace";
                            font-size: 8px;
                            vertical-alignment: center;
                            x: 6px;
                        }
                    }
                }
            }
        }
    }

}
