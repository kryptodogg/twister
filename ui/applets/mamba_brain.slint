import { VerticalBox, HorizontalBox } from "std-widgets.slint";
import { Colors, Spacing, Typography } from "../tokens.slint";

export global MambaBrainStatus {
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    // RESPONSIVE SIZING — AR/VR Deployment
    // unit-size = height of golden-ratio credit card (1.585:1)
    // Scales responsively: phone (212pt) → widget (54pt) → display (540pt)
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    in property <length> unit-size: 100px;

    // Canvas dimension for particle sizing (computed from visualization rectangle)
    in property <length> canvas-dimension: 100px;

    // Scalar latent metrics from 128D → 4D projection
    in-out property <float> frequency-tracker: 0.0;
    in-out property <float> harmonic-smear: 0.0;
    in-out property <float> anomaly-score: 0.0;
    in-out property <float> material-confidence: 0.0;

    // Particle positions (12 clusters) - format: "x,y,energy|x,y,energy|..."
    in-out property <string> particle-positions: "";

    // Pre-parsed particle data (12 particles × 3 values = 36 floats)
    // These are populated by parsing particle-positions string in Rust
    in-out property <[float]> particle-data: [
        0.0,
        0.0,
        0.5,  // Particle 0
        0.0,
        0.0,
        0.5,  // Particle 1
        0.0,
        0.0,
        0.5,  // Particle 2
        0.0,
        0.0,
        0.5,  // Particle 3
        0.0,
        0.0,
        0.5,  // Particle 4
        0.0,
        0.0,
        0.5,  // Particle 5
        0.0,
        0.0,
        0.5,  // Particle 6
        0.0,
        0.0,
        0.5,  // Particle 7
        0.0,
        0.0,
        0.5,  // Particle 8
        0.0,
        0.0,
        0.5,  // Particle 9
        0.0,
        0.0,
        0.5,  // Particle 10
        0.0,
        0.0,
        0.5,  // Particle 11
    ];

    // Inference status
    in-out property <bool> inference-active: false;
        in-out property <int> inference-fps: 60;

    // UI state
    in-out property <bool> metrics-panel-visible: true;
    }

// Helper component: Particle dot with energy-based opacity
// Responsive sizing: dot-radius = min(canvas_width, canvas_height) * 0.015
component ParticleDot inherits Rectangle {
        in property <float> energy: 0.5;      // [0, 1]
    in property <color> dot-color: Colors.primary;
    in property <length> canvas-dimension: 400px;  // Canvas shorter dimension for scaling

    property <length> dot-size: max(3px, canvas-dimension * 0.015);  // 1.5% of canvas, min 3px

    width: dot-size;
    height: dot-size;
    border-radius: dot-size * 0.5;
        background: dot-color;
        opacity: 0.2 + 0.8 * energy;

    // Smooth opacity animation
    animate opacity {
            duration: 100ms;
            easing: ease-in-out;
        }
    }

// Helper component: Metric card with responsive sizing
component MetricCard inherits Rectangle {
        in property <string> label: "";
        in property <float> value: 0.0;
        in property <string> formatted-value: "";
        in property <color> accent-color: Colors.primary;
        background: Colors.surface-container;
        border-color: accent-color;
        border-width: 1px;
        border-radius: 6px;
        horizontal-stretch: 1;
        VerticalBox {
            padding: 12px;
            spacing: 4px;
            Text {
                text: label;
                color: accent-color;
                font-weight: 700;
                font-size: 11px;
                font-family: "monospace";
            }

            Text {
                text: formatted-value;
                color: accent-color;
                font-family: "monospace";
                font-size: 16px;
                font-weight: 700;
            }
        }
    }

    export component MambaBrainApplet inherits Window {
        title: "AG-Brain: Unified Field Inference";
    // Resizable window - responsive sizing
    // Default: 1200x700px (12x unit-size), scales with unit-size property
    width: MambaBrainStatus.unit-size * 12.0;
        height: MambaBrainStatus.unit-size * 7.0;
    // Transparent window background — DWM Acrylic/KWin blur shows through
    // Fallback to solid if compositor not available is handled in Rust
    background: transparent;

    // Update canvas-dimension based on visualization rectangle size
    // This drives responsive particle sizing
    property <length> canvas-rect-width: self.width * 0.65;  // Particle canvas is ~65% of total width
    property <length> canvas-rect-height: self.height * 0.75; // Particle canvas is ~75% of total height

    init => {
        MambaBrainStatus.canvas-dimension = (canvas-rect-width < canvas-rect-height) ? canvas-rect-width : canvas-rect-height;
    }
        VerticalBox {
            spacing: Spacing.md;
            padding: Spacing.md;

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // HEADER: Inference Status with Material Controls
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        Rectangle {
                background: Colors.surface-container;
                border-radius: Spacing.md * 0.5;
                border-color: Colors.primary;
                border-width: 1px;
                height: MambaBrainStatus.unit-size * 0.6;
                HorizontalBox {
                    padding: Spacing.sm;
                    spacing: Spacing.lg;
                    alignment: space-between;

                // Left side: Status indicator
                VerticalBox {
                        spacing: 2px;
                        Text {
                            text: MambaBrainStatus.inference-active ? "🧠 MAMBA BRAIN ACTIVE" : "🧠 STANDBY";
                            color: MambaBrainStatus.inference-active ? Colors.primary : Colors.harm-1;
                            font-weight: 800;
                            font-size: Typography.label-large;
                            font-family: "monospace";
                        }

                        Text {
                            text: "Unified Field Inference @ " + MambaBrainStatus.inference-fps + " FPS";
                            color: Colors.on-surface-variant;
                            font-family: "monospace";
                            font-size: Typography.label-small;
                        }
                    }

                // Right side: Quick metrics + toggle button
                HorizontalBox {
                        spacing: 20px;
                        alignment: end;

                    // Quick metric displays
                    HorizontalBox {
                            spacing: Spacing.lg;
                            VerticalBox {
                                spacing: Spacing.xs;
                                Text {
                                    text: "Anomaly";
                                    color: Colors.on-surface-variant;
                                    font-size: Typography.label-small;
                                    font-family: "monospace";
                                }

                                Text {
                                    text: round(MambaBrainStatus.anomaly-score * 1000.0) / 1000.0;
                                    color: MambaBrainStatus.anomaly-score > 0.5 ? Colors.error : Colors.primary;
                                    font-family: "monospace";
                                    font-weight: 700;
                                    font-size: Typography.mono-label;
                                }
                            }

                            VerticalBox {
                                spacing: Spacing.xs;
                                Text {
                                    text: "Confidence";
                                    color: Colors.on-surface-variant;
                                    font-size: Typography.label-small;
                                    font-family: "monospace";
                                }

                                Text {
                                    text: round(MambaBrainStatus.material-confidence * 100.0) + "%";
                                    color: Colors.primary;
                                    font-family: "monospace";
                                    font-weight: 700;
                                    font-size: Typography.mono-label;
                                }
                            }
                        }

                    // Material Design toggle button (gear icon)
                    Rectangle {
                            width: MambaBrainStatus.unit-size * 0.36;
                            height: MambaBrainStatus.unit-size * 0.36;
                            border-radius: Spacing.sm * 0.5;
                            background: transparent;
                            border-width: 1px;
                            border-color: Colors.primary;
                            Text {
                                text: MambaBrainStatus.metrics-panel-visible ? "⚙️" : "📊";
                                font-size: Typography.headline-small;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: 100%;
                                height: 100%;
                            }

                            TouchArea {
                                clicked => {
                                    MambaBrainStatus.metrics-panel-visible = !MambaBrainStatus.metrics-panel-visible;
                                }
                            }
                        }
                    }
                }
            }

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // MAIN CONTENT: Particle visualization + optional metrics
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        HorizontalBox {
                spacing: 12px;
                horizontal-stretch: 1;
                vertical-stretch: 1;

            // Left: Particle cloud visualization
            Rectangle {
                    background: Colors.surface-container;
                    border-color: Colors.secondary;
                    border-width: 2px;
                    border-radius: Spacing.md * 0.5;
                    horizontal-stretch: 1;
                    VerticalBox {
                        padding: Spacing.sm;
                        spacing: Spacing.sm;
                        Text {
                            text: "128D Latent → 2D PCA | " + MambaBrainStatus.inference-fps + " Hz update";
                            color: Colors.secondary;
                            font-weight: 700;
                            font-size: Typography.label-small;
                            font-family: "monospace";
                        }

                    // Particle visualization canvas
                    Rectangle {
                            width: 100%;
                            height: 100%;
                            background: @linear-gradient(135deg, Colors.canvas-background 0%, Colors.surface-dim 100%);
                            border-radius: Spacing.sm;

                            HorizontalBox {
                                padding: Spacing.lg;
                                spacing: Spacing.md;

                            // Left column: Particle dots (6 particles)
                            VerticalBox {
                                    spacing: Spacing.md;
                                    ParticleDot {
                                        dot-color: Colors.harm-0;
                                        energy: MambaBrainStatus.particle-data[2];
                                        canvas-dimension: MambaBrainStatus.canvas-dimension;
                                    }

                                    ParticleDot {
                                        dot-color: Colors.harm-8;
                                        energy: MambaBrainStatus.particle-data[5];
                                        canvas-dimension: MambaBrainStatus.canvas-dimension;
                                    }

                                    ParticleDot {
                                        dot-color: Colors.harm-11;
                                        energy: MambaBrainStatus.particle-data[8];
                                        canvas-dimension: MambaBrainStatus.canvas-dimension;
                                    }

                                    ParticleDot {
                                        dot-color: Colors.harm-3;
                                        energy: MambaBrainStatus.particle-data[11];
                                        canvas-dimension: MambaBrainStatus.canvas-dimension;
                                    }

                                    ParticleDot {
                                        dot-color: Colors.harm-9;
                                        energy: MambaBrainStatus.particle-data[14];
                                        canvas-dimension: MambaBrainStatus.canvas-dimension;
                                    }

                                    ParticleDot {
                                        dot-color: Colors.harm-1;
                                        energy: MambaBrainStatus.particle-data[17];
                                        canvas-dimension: MambaBrainStatus.canvas-dimension;
                                    }
                                }

                            // Center: Energy visualization (animated bars)
                            VerticalBox {
                                    spacing: Spacing.sm;
                                    horizontal-stretch: 1;
                                    Rectangle {
                                        height: 4px;
                                        width: 100%;
                                        background: Colors.surface-container-low;
                                        border-radius: 2px;
                                        Rectangle {
                                            height: 100%;
                                            background: Colors.harm-0;
                                            width: max(10px, parent.width * (0.4 + MambaBrainStatus.frequency-tracker * 0.6));
                                            animate width {
                                                duration: 100ms;
                                                easing: ease-in-out;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        height: 4px;
                                        width: 100%;
                                        background: Colors.surface-container-low;
                                        border-radius: 2px;
                                        Rectangle {
                                            height: 100%;
                                            background: Colors.harm-8;
                                            width: max(10px, parent.width * (0.3 + MambaBrainStatus.harmonic-smear * 0.7));
                                            animate width {
                                                duration: 100ms;
                                                easing: ease-in-out;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        height: 4px;
                                        width: 100%;
                                        background: Colors.surface-container-low;
                                        border-radius: 2px;
                                        Rectangle {
                                            height: 100%;
                                            background: Colors.harm-11;
                                            width: max(10px, parent.width * (0.2 + MambaBrainStatus.anomaly-score * 0.8));
                                            animate width {
                                                duration: 100ms;
                                                easing: ease-in-out;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        height: 4px;
                                        width: 100%;
                                        background: Colors.surface-container-low;
                                        border-radius: 2px;
                                        Rectangle {
                                            height: 100%;
                                            background: Colors.harm-3;
                                            width: max(10px, parent.width * (0.35 + MambaBrainStatus.material-confidence * 0.65));
                                            animate width {
                                                duration: 100ms;
                                                easing: ease-in-out;
                                            }
                                        }
                                    }
                                }

                            // Right column: Remaining particles (6 particles)
                            VerticalBox {
                                    spacing: Spacing.md;
                                    ParticleDot {
                                        dot-color: Colors.harm-7;
                                        energy: MambaBrainStatus.particle-data[20];
                                        canvas-dimension: MambaBrainStatus.canvas-dimension;
                                    }

                                    ParticleDot {
                                        dot-color: Colors.harm-11;
                                        energy: MambaBrainStatus.particle-data[23];
                                        canvas-dimension: MambaBrainStatus.canvas-dimension;
                                    }

                                    ParticleDot {
                                        dot-color: Colors.harm-9;
                                        energy: MambaBrainStatus.particle-data[26];
                                        canvas-dimension: MambaBrainStatus.canvas-dimension;
                                    }

                                    ParticleDot {
                                        dot-color: Colors.harm-1;
                                        energy: MambaBrainStatus.particle-data[29];
                                        canvas-dimension: MambaBrainStatus.canvas-dimension;
                                    }

                                    ParticleDot {
                                        dot-color: Colors.harm-3;
                                        energy: MambaBrainStatus.particle-data[32];
                                        canvas-dimension: MambaBrainStatus.canvas-dimension;
                                    }

                                    ParticleDot {
                                        dot-color: Colors.harm-7;
                                        energy: MambaBrainStatus.particle-data[35];
                                        canvas-dimension: MambaBrainStatus.canvas-dimension;
                                    }
                                }
                            }
                        }
                    }
                }

            // Right side: Metrics panel (togglable via gear icon)
            Rectangle {
                    width: MambaBrainStatus.metrics-panel-visible ? MambaBrainStatus.unit-size * 2.4 : 0px;
                    height: 100%;
                    background: Colors.surface-container;
                    border-color: Colors.primary;
                    border-width: 1px;
                    border-radius: Spacing.md * 0.5;
                    opacity: MambaBrainStatus.metrics-panel-visible ? 1.0 : 0.0;
                    animate width {
                        duration: 200ms;
                        easing: ease-in-out;
                    }
                    animate opacity { duration: 200ms; }
                    VerticalBox {
                        padding: Spacing.sm;
                        spacing: Spacing.md;
                        Text {
                            text: "METRICS";
                            color: Colors.primary;
                            font-weight: 700;
                            font-size: Typography.label-small;
                            font-family: "monospace";
                        }

                    // Frequency metric card
                    MetricCard {
                            label: "📡 FREQUENCY";
                            formatted-value: round(MambaBrainStatus.frequency-tracker * 100.0) + "%";
                            accent-color: Colors.harm-0;
                        }

                    // Harmonic metric card
                    MetricCard {
                            label: "🌊 HARMONIC";
                            formatted-value: round(MambaBrainStatus.harmonic-smear * 1000.0) / 1000.0;
                            accent-color: Colors.harm-8;
                        }

                    // Anomaly metric card
                    MetricCard {
                            label: "⚠️ ANOMALY";
                            formatted-value: round(MambaBrainStatus.anomaly-score * 1000.0) / 1000.0;
                            accent-color: Colors.harm-11;
                        }

                    // Confidence metric card
                    MetricCard {
                            label: "🎯 CONFIDENCE";
                            formatted-value: round(MambaBrainStatus.material-confidence * 1000.0) / 1000.0;
                            accent-color: Colors.primary;
                        }

                    // Status bar
                    Rectangle {
                            height: Typography.body-medium * 1.5;
                            background: transparent;
                            border-color: Colors.outline-variant;
                            border-width: 1px;
                            border-radius: Spacing.sm * 0.5;
                            Text {
                                text: MambaBrainStatus.inference-active ? "✓ Running" : "⊘ Waiting";
                                color: MambaBrainStatus.inference-active ? Colors.harm-9 : Colors.harm-1;
                                font-family: "monospace";
                                font-size: Typography.label-small;
                                vertical-alignment: center;
                                x: Spacing.sm;
                            }
                        }
                    }
                }
            }
        }
    }
