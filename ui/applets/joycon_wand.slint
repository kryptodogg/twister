import { VerticalBox, HorizontalBox } from "std-widgets.slint";

export global JoyconStatus {
    in-out property <bool> connected;
    in-out property <float> gyro-roll;
    in-out property <float> gyro-pitch;
    in-out property <float> gyro-yaw;
    in-out property <float> accel-x;
    in-out property <float> accel-y;
    in-out property <float> accel-z;
    in-out property <float> trigger-r;
    in-out property <float> heterodyne-strength;
    in-out property <string> sparkline-path: "M 0 20 L 120 20";
}

component Dial {
    in property <string> title;
    in property <float> angle;
    in property <color> primary-color: #0cf;

    VerticalBox {
        spacing: 2px;
        Text {
            text: root.title;
            color: root.primary-color;
            font-size: 10px;
            font-family: "monospace";
            horizontal-alignment: center;
        }
        Rectangle {
            width: 40px;
            height: 40px;
            border-radius: 20px;
            border-width: 1px;
            border-color: #333;

            // Simple indicator without rotation
            Rectangle {
                width: 4px;
                height: 4px;
                border-radius: 2px;
                background: root.primary-color;
                // Basic trig to position dot on circle
                // We'll just map angle directly to a position since we can't use rotation
                x: 18px + 16px * sin(root.angle * 1deg);
                y: 18px - 16px * cos(root.angle * 1deg);
            }
            Text {
                text: round(root.angle) + "°";
                font-size: 10px;
                color: #fff;
                font-family: "monospace";
                horizontal-alignment: center;
                y: 14px;
            }
        }
    }
}

export component JoyconWandApplet inherits Window {
    title: "AG-UI: Wizard Wand Telemetry";
    width: 160px;
    height: 480px;
    background: #000000aa;

    // Frost glass effect hack
    Rectangle {
        width: 100%;
        height: 100%;
        background: @linear-gradient(180deg, #11111166 0%, #000000bb 100%);
    }

    VerticalBox {
        spacing: 12px;
        padding: 10px;

        Text {
            text: JoyconStatus.connected ? "WAND ACTIVE" : "SEARCHING...";
            color: JoyconStatus.connected ? #0f0 : #f00;
            font-size: 11px;
            font-family: "monospace";
            font-weight: 800;
            horizontal-alignment: center;
        }

        Rectangle { height: 1px; background: #333; }

        Text { text: "ATTITUDE"; color: #0cf; font-size: 10px; font-family: "monospace"; font-weight: 700; horizontal-alignment: center; }

        HorizontalBox {
            spacing: 10px;
            alignment: center;
            Dial { title: "ROLL"; angle: JoyconStatus.gyro-roll; }
            Dial { title: "PITCH"; angle: JoyconStatus.gyro-pitch; }
        }

        HorizontalBox {
            alignment: center;
            Dial { title: "YAW"; angle: JoyconStatus.gyro-yaw; }
        }

        Rectangle { height: 1px; background: #333; }

        VerticalBox {
            spacing: 5px;
            Text { text: "RF SYNTHESIS"; color: #b0f; font-size: 10px; font-family: "monospace"; font-weight: 700; }
            Text { text: "PWR: " + round(JoyconStatus.trigger-r) + "/255"; color: #fff; font-size: 10px; font-family: "monospace"; }
            Text { text: "SHK: " + round(JoyconStatus.heterodyne-strength * 100) + "%"; color: #b0f; font-size: 10px; font-family: "monospace"; }
        }

        // Resonance Sparkline
        Rectangle {
            height: 40px;
            width: 140px;
            border-color: #333;
            border-width: 1px;
            background: #000;

            Path {
                width: 100%;
                height: 100%;
                stroke: #b0f;
                stroke-width: 1.5px;
                commands: JoyconStatus.sparkline-path;
            }
        }
    }
}
