import { VerticalBox, HorizontalBox, Slider, Switch, ProgressIndicator, Button } from "std-widgets.slint";
import { Standards, IconButton } from "../standards.slint";

export global ChronosEngine {
    // Temperature (τ) parameter: 0.01 to 1.0
    // Default: 0.07 (generation-critical for harassment pattern discovery)
    in-out property <float> temperature: 0.07;

    // Learning rate: 1e-6 to 1e-1
    in-out property <float> learning-rate: 0.001;

    // Prediction horizon in seconds: 1 to 3600
    in-out property <int> prediction-horizon-secs: 60;

    // Training state
    in-out property <bool> training-active: false;
    in-out property <float> current-loss: 2.1;
    in-out property <float> epoch-progress: 0.0; // 0.0 to 1.0
    in-out property <int> current-epoch: 0;
    in-out property <int> total-epochs: 50;

    // UI State
    in-out property <bool> advanced-expanded: false;
    in-out property <string> status-message: "Ready to train";
    in-out property <color> status-color: Standards.secondary;

    // Temperature change callback (to notify Rust backend)
    callback temperature-changed(float);
    callback learning-rate-changed(float);
    callback prediction-horizon-changed(int);
    callback start-training();
    callback stop-training();
}

export component ChronosApplet inherits Window {
    title: "Chronos: TimeGNN Contrastive Training";
    width: 900px;
    height: 700px;
    background: Standards.background;

    no-frame: true;

    VerticalBox {
        spacing: 15px;
        padding: 20px;

        // ============================================
        // Header Section
        // ============================================
        HorizontalBox {
            spacing: 10px;

            VerticalBox {
                spacing: 5px;
                Text {
                    text: "CHRONOS: TIMEGNN CONTRASTIVE TRAINING";
                    color: Standards.primary;
                    font-weight: 800;
                    font-size: 18px;
                    font-family: "Courier New";
                }
                HorizontalBox {
                    spacing: 15px;
                    Text {
                        text: "τ = " + round(ChronosEngine.temperature * 1000) / 1000;
                        color: ChronosEngine.temperature < 0.1 ? Standards.error : Standards.secondary;
                        font-weight: 700;
                        font-family: "Courier New";
                    }
                    Text {
                        text: "Loss = " + round(ChronosEngine.current-loss * 10000) / 10000;
                        color: ChronosEngine.current-loss > 1.0 ? Standards.error : Standards.secondary;
                        font-weight: 700;
                        font-family: "Courier New";
                    }
                    Text {
                        text: "E" + pad-number(ChronosEngine.current-epoch) + "/" + ChronosEngine.total-epochs;
                        color: Standards.on-surface;
                        font-family: "Courier New";
                    }
                }
            }

            HorizontalBox {
                alignment: end;
                spacing: 10px;
                Text {
                    text: ChronosEngine.status-message;
                    color: ChronosEngine.status-color;
                    font-weight: 600;
                    font-family: "Courier New";
                    vertical-alignment: center;
                }
                Switch {
                    checked <=> ChronosEngine.training-active;
                    toggled => {
                        if (self.checked) {
                            ChronosEngine.start-training();
                        } else {
                            ChronosEngine.stop-training();
                        }
                    }
                }
            }
        }

        // ============================================
        // Loss Convergence Visualization
        // ============================================
        Rectangle {
            height: 200px;
            background: Standards.surface;
            border-color: Standards.surface-variant;
            border-width: 2px;
            border-radius: 8px;

            VerticalBox {
                padding: 15px;
                spacing: 10px;

                // Graph Label
                Text {
                    text: "Loss Convergence Trajectory";
                    color: Standards.on-surface;
                    font-weight: 700;
                    font-family: "Courier New";
                }

                // Loss indicator bar (visual representation of convergence)
                HorizontalBox {
                    spacing: 10px;
                    // Baseline (starting loss ~2.1)
                    Rectangle {
                        width: 40px;
                        height: 30px;
                        background: Standards.surface-variant;
                        Text {
                            text: "2.1";
                            color: Standards.error;
                            font-size: 11px;
                            horizontal-alignment: center;
                        }
                    }

                    // Progress indicator (current loss position)
                    Rectangle {
                        background: Standards.surface-variant;
                        border-color: Standards.primary;
                        border-width: 1px;

                        HorizontalLayout {
                            padding: 5px;
                            Rectangle {
                                horizontal-stretch: max(0.01, min(1.0, 1.0 - (ChronosEngine.current-loss - 0.34) / (2.1 - 0.34)));
                                background: ChronosEngine.current-loss > 1.0 ? Standards.error :
                                          ChronosEngine.current-loss > 0.5 ? Standards.secondary :
                                          Standards.primary;
                            }
                            Rectangle {
                                horizontal-stretch: max(0.0, min(0.99, (ChronosEngine.current-loss - 0.34) / (2.1 - 0.34)));
                            }
                        }
                    }

                    // Target (convergence goal ~0.34)
                    Rectangle {
                        width: 40px;
                        height: 30px;
                        background: Standards.surface-variant;
                        Text {
                            text: "< 0.34";
                            color: Standards.primary;
                            font-size: 11px;
                            horizontal-alignment: center;
                        }
                    }
                }

                // Epoch progress
                HorizontalBox {
                    spacing: 10px;
                    Text {
                        text: "Epoch Progress:";
                        color: Standards.on-surface;
                        font-family: "Courier New";
                        vertical-alignment: center;
                    }
                    ProgressIndicator {
                        progress: ChronosEngine.epoch-progress;
                    }
                    Text {
                        text: round(ChronosEngine.epoch-progress * 1000) / 10 + "%";
                        color: Standards.on-surface;
                        font-family: "Courier New";
                        width: 50px;
                    }
                }
            }
        }

        // ============================================
        // Temperature (τ) Control
        // ============================================
        Rectangle {
            background: Standards.surface;
            border-color: Standards.surface-variant;
            border-width: 1px;
            border-radius: 6px;
            padding: 15px;

            VerticalBox {
                spacing: 10px;

                HorizontalBox {
                    Text {
                        text: "Temperature (τ): Contrastive Sharpness";
                        color: Standards.primary;
                        font-weight: 700;
                        font-family: "Courier New";
                    }
                    Text {
                        text: round(ChronosEngine.temperature * 10000) / 10000;
                        color: Standards.secondary;
                        font-weight: 700;
                        font-family: "Courier New";
                        horizontal-alignment: right;
                    }
                }

                // Temperature slider (0.01 to 1.0)
                HorizontalBox {
                    spacing: 10px;
                    Text {
                        text: "0.01";
                        color: Standards.on-surface;
                        font-size: 10px;
                        width: 30px;
                    }

                    Slider {
                        value <=> ChronosEngine.temperature;
                        minimum: 0.01;
                        maximum: 1.0;
                        changed(new-value) => {
                            ChronosEngine.temperature-changed(new-value);
                        }
                    }

                    Text {
                        text: "1.0";
                        color: Standards.on-surface;
                        font-size: 10px;
                        width: 30px;
                    }
                }

                // Temperature explanation
                Text {
                    text: "Lower τ → Sharp clustering (harassment vs normal)  |  Higher τ → Soft clustering (exploration)";
                    color: Standards.secondary;
                    font-size: 9px;
                    font-family: "Courier New";
                }
            }
        }

        // ============================================
        // Learning Rate Control
        // ============================================
        Rectangle {
            background: Standards.surface;
            border-color: Standards.surface-variant;
            border-width: 1px;
            border-radius: 6px;
            padding: 15px;

            VerticalBox {
                spacing: 10px;

                HorizontalBox {
                    Text {
                        text: "Learning Rate (Adam): Gradient Step Size";
                        color: Standards.primary;
                        font-weight: 700;
                        font-family: "Courier New";
                    }
                    Text {
                        text: format-learning-rate(ChronosEngine.learning-rate);
                        color: Standards.secondary;
                        font-weight: 700;
                        font-family: "Courier New";
                        horizontal-alignment: right;
                    }
                }

                // Learning rate slider (log scale: -6 to -1 = 1e-6 to 1e-1)
                HorizontalBox {
                    spacing: 10px;
                    Text {
                        text: "1e-6";
                        color: Standards.on-surface;
                        font-size: 10px;
                        width: 35px;
                    }

                    Slider {
                        // Using linear slider, map display to actual values
                        value: log10-inverse(ChronosEngine.learning-rate);
                        minimum: -6.0;
                        maximum: -1.0;
                        changed(new-log-value) => {
                            let new-lr = pow(10.0, new-log-value);
                            ChronosEngine.learning-rate = new-lr;
                            ChronosEngine.learning-rate-changed(new-lr);
                        }
                    }

                    Text {
                        text: "1e-1";
                        color: Standards.on-surface;
                        font-size: 10px;
                        width: 35px;
                    }
                }

                // Learning rate explanation
                Text {
                    text: "Higher LR → Faster convergence but may overshoot  |  Lower LR → Slower but more stable";
                    color: Standards.secondary;
                    font-size: 9px;
                    font-family: "Courier New";
                }
            }
        }

        // ============================================
        // Prediction Horizon Control
        // ============================================
        Rectangle {
            background: Standards.surface;
            border-color: Standards.surface-variant;
            border-width: 1px;
            border-radius: 6px;
            padding: 15px;

            VerticalBox {
                spacing: 10px;

                HorizontalBox {
                    Text {
                        text: "Prediction Horizon: Temporal Context";
                        color: Standards.primary;
                        font-weight: 700;
                        font-family: "Courier New";
                    }
                    Text {
                        text: ChronosEngine.prediction-horizon-secs + "s";
                        color: Standards.secondary;
                        font-weight: 700;
                        font-family: "Courier New";
                        horizontal-alignment: right;
                    }
                }

                // Prediction horizon slider (1 to 3600 seconds)
                HorizontalBox {
                    spacing: 10px;
                    Text {
                        text: "1s";
                        color: Standards.on-surface;
                        font-size: 10px;
                        width: 30px;
                    }

                    Slider {
                        value: ChronosEngine.prediction-horizon-secs;
                        minimum: 1;
                        maximum: 3600;
                        changed(new-value) => {
                            ChronosEngine.prediction-horizon-secs = round(new-value);
                            ChronosEngine.prediction-horizon-changed(ChronosEngine.prediction-horizon-secs);
                        }
                    }

                    Text {
                        text: "1h";
                        color: Standards.on-surface;
                        font-size: 10px;
                        width: 30px;
                    }
                }

                // Horizon explanation
                Text {
                    text: "Time window for attention mechanism: Longer horizon = larger temporal context for pattern matching";
                    color: Standards.secondary;
                    font-size: 9px;
                    font-family: "Courier New";
                }
            }
        }
    }

    // ============================================
    // Helper Functions
    // ============================================

    function pad-number(n: int) -> string {
        if (n < 10) {
            return "0" + n;
        } else {
            return n;
        }
    }

    function format-learning-rate(lr: float) -> string {
        if (lr >= 0.01) {
            return round(lr * 10000) / 10000;
        } else if (lr >= 0.0001) {
            return round(lr * 1000000) / 1000000;
        } else {
            return "< 0.0001";
        }
    }

    function log10-inverse(value: float) -> float {
        // Returns log10 of the value
        if (value <= 0.0) {
            return -6.0;
        }
        if (value < 0.00001) { return -6.0; }
        if (value < 0.0001) { return -5.0; }
        if (value < 0.001) { return -4.0; }
        if (value < 0.01) { return -3.0; }
        if (value < 0.1) { return -2.0; }
        return -1.0;
    }

    function pow(base: float, exp: float) -> float {
        // Simplified power function for log scale
        if (exp == -6.0) { return 0.000001; }
        if (exp == -5.0) { return 0.00001; }
        if (exp == -4.0) { return 0.0001; }
        if (exp == -3.0) { return 0.001; }
        if (exp == -2.0) { return 0.01; }
        if (exp == -1.0) { return 0.1; }
        return 1.0;
    }
}


