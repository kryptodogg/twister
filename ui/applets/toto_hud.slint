// ui/applets/toto_hud.slint
// Toto HUD Applet — Compact Floating Instrument Widget (Slint)
// Ported from: assets/prototyping/Compact_Floating_Instrument_Widget/src/app/App.tsx

import { Colors } from "../tokens.slint";

// ─────────────────────────────────────────────────────────────────────────────
// Small primitives (custom, to keep the applet self-contained)
// ─────────────────────────────────────────────────────────────────────────────

component Divider inherits Rectangle {
    in property <length> thickness: 1px;
    in property <length> divider-height: 50px;
    width: thickness;
    height: divider-height;
    background: Colors.outline;
}

component ToggleSwitch inherits Rectangle {
    in-out property <bool> checked: true;
    in property <length> rem: 16px;

    property <length> h: rem * 0.75;
    property <length> w: rem * 1.5;
    property <length> pad: rem * 0.08;

    width: w;
    height: h;
    border-radius: h / 2;
    border-width: rem * 0.06;
    border-color: checked ? Colors.primary : Colors.outline;
    background: checked ? Colors.primary.with-alpha(0.25) : Colors.surface-container-low;

    Rectangle {
        width: h - pad * 2;
        height: h - pad * 2;
        border-radius: self.height / 2;
        x: checked ? parent.width - self.width - pad : pad;
        y: pad;
        background: checked ? Colors.primary : Colors.on-surface-variant;
        animate x { duration: 150ms; easing: ease-in-out; }
        animate background { duration: 150ms; easing: ease-in-out; }
    }

    animate background { duration: 150ms; easing: ease-in-out; }
    animate border-color { duration: 150ms; easing: ease-in-out; }

    TouchArea {
        clicked => { root.checked = !root.checked; }
    }
}

component ChipButton inherits Rectangle {
    in property <string> label;
    in property <string> icon;
    in property <length> rem: 16px;
    callback clicked;

    height: rem * 2.25;
    border-radius: rem * 0.375;
    background: Colors.canvas-background;
    border-color: Colors.outline;
    border-width: rem * 0.06;

    states [
        hover when touch.has-hover: { background: Colors.surface-container-low; }
        pressed when touch.pressed: { background: Colors.surface-container; }
    ]
    animate background { duration: 120ms; }

    HorizontalLayout {
        padding: rem * 0.375;
        spacing: rem * 0.3;
        alignment: center;

        Text {
            text: icon;
            color: Colors.on-surface-variant;
            font-size: rem * 0.9;
            font-family: "monospace";
            vertical-alignment: center;
        }

        Text {
            text: label;
            color: Colors.on-surface-variant;
            font-size: rem * 0.8;
            font-weight: 500;
            vertical-alignment: center;
        }
    }

    touch := TouchArea { clicked => root.clicked(); }
}

component DenialItem inherits Rectangle {
    in property <string> label;
    in property <string> freq;
    in-out property <bool> active: false;
    in property <length> rem: 16px;

    height: rem * 2.25;
    border-radius: rem * 0.25;
    background: Colors.surface-dim;
    border-width: rem * 0.06;
    border-color: active ? Colors.secondary : Colors.outline;

    HorizontalLayout {
        padding: rem * 0.375;
        spacing: rem * 0.5;

        VerticalLayout {
            spacing: rem * 0.125;

            Text {
                text: label;
                color: active ? Colors.on-surface : Colors.on-surface-variant;
                font-size: rem * 0.75;
                font-weight: 500;
            }

            Text {
                text: freq;
                color: Colors.on-surface-variant.with-alpha(0.7);
                font-size: rem * 0.65;
                font-family: "monospace";
            }
        }

        Rectangle { horizontal-stretch: 1; background: transparent; }

        ToggleSwitch { rem: root.rem; checked <=> root.active; }
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// TotoHudApplet
// ─────────────────────────────────────────────────────────────────────────────

export component TotoHudApplet inherits Window {
    title: "Toto · Compact Floating Instrument";
    no-frame: true;
    background: transparent;

    // Public properties (wired from Rust)
    in-out property <length> unit-size: 384px;
    in-out property <bool> expanded: false;

    in-out property <float> anomaly-score: 0.0;
    in-out property <bool> auto-steer: true;
    in-out property <float> dominant-freq-hz: 0.0;

    // Viewbox space: 0..100 x 0..100
    in-out property <string> wave-path: "M 0 50 L 100 50";

    in-out property <float> learning-loss: 0.0;
    in-out property <string> loss-path: "M 0 100 L 100 100";

    in-out property <bool> dvr-recording: false;
    in-out property <int> dvr-buffer-days: 0;

    in-out property <color> resonant-color: Colors.primary;

    // FieldPipeline projections (Track A-1)
    in-out property <float> drive: 0.0;
    in-out property <float> fold: 0.0;
    in-out property <float> asym: 0.0;

    // Animation tick for smooth transitions
    in-out property <float> animation-tick: 0.0;

    // "rem" derived from unit-size (default unit-size=384 => rem=16)
    property <length> rem: unit-size / 24;

    // Root sizing: maintain credit-card aspect ratio when collapsed
    property <length> collapsed-height: unit-size / 1.6;
    property <length> settings-height: rem * 10.25;

    width: unit-size;
    height: collapsed-height + (expanded ? settings-height : 0);

    animate height { duration: 400ms; easing: ease-in-out; }
    animate resonant-color { duration: 400ms; easing: ease-in-out; }

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: Colors.surface-dim;
        border-radius: rem * 0.75;
        border-width: rem * 0.06;
        border-color: Colors.outline;
        clip: true;

        VerticalLayout {
            padding: rem * 0.5;
            spacing: rem * 0.375;

            // ═══════════════════════════════════════════════════════════════
            // HEADER PANEL
            // ═══════════════════════════════════════════════════════════════
            Rectangle {
                height: rem * 2.5;
                background: Colors.canvas-background;
                border-radius: rem * 0.375;
                border-width: rem * 0.06;
                border-color: Colors.outline;

                HorizontalLayout {
                    padding-left: rem * 0.75;
                    padding-right: rem * 0.75;
                    spacing: rem * 0.75;
                    alignment: center;

                    HorizontalLayout {
                        spacing: rem * 0.75;
                        alignment: center;

                        Text {
                            text: "TOTO CORE";
                            color: Colors.primary;
                            font-size: rem * 0.85;
                            font-weight: 700;
                            letter-spacing: rem * 0.05;
                        }

                        Divider { thickness: rem * 0.06; height: rem * 1.0; }

                        HorizontalLayout {
                            spacing: rem * 0.375;
                            alignment: center;

                            Text {
                                text: "Anomaly Score";
                                color: Colors.on-surface-variant;
                                font-size: rem * 0.75;
                                font-weight: 500;
                            }

                            Text {
                                text: round(anomaly-score * 1000) / 1000;
                                color: resonant-color;
                                font-size: rem * 0.8;
                                font-family: "monospace";
                                font-weight: 700;
                            }
                        }
                    }

                    Rectangle { horizontal-stretch: 1; background: transparent; }

                    HorizontalLayout {
                        spacing: rem * 0.5;
                        alignment: center;

                        Text {
                            text: "Neural Auto-Steer";
                            color: Colors.primary.with-alpha(0.8);
                            font-size: rem * 0.75;
                            font-weight: 500;
                        }

                        ToggleSwitch { rem: root.rem; checked <=> root.auto-steer; }
                    }
                }
            }

            // ═══════════════════════════════════════════════════════════════
            // OSCILLOSCOPE CANVAS
            // ═══════════════════════════════════════════════════════════════
            Rectangle {
                vertical-stretch: 1;
                background: Colors.canvas-background;
                border-radius: rem * 0.375;
                border-width: rem * 0.06;
                border-color: Colors.outline;
                clip: true;

                // Horizontal grid (6 rows)
                for i in [1, 2, 3, 4, 5]: Rectangle {
                    x: 0;
                    y: parent.height * (i * 1.0 / 6.0);
                    width: parent.width;
                    height: rem * 0.06;
                    background: Colors.outline.with-alpha(i == 3 ? 0.6 : 0.25);
                }

                // Vertical grid (10 columns)
                for j in [1, 2, 3, 4, 5, 6, 7, 8, 9]: Rectangle {
                    x: parent.width * (j * 1.0 / 10.0);
                    y: 0;
                    width: rem * 0.06;
                    height: parent.height;
                    background: Colors.outline.with-alpha(0.2);
                }

                // Glow pass
                Path {
                    width: parent.width;
                    height: parent.height;
                    viewbox-x: 0;
                    viewbox-y: 0;
                    viewbox-width: 100;
                    viewbox-height: 100;
                    commands: wave-path;
                    stroke: resonant-color.with-alpha(0.35);
                    stroke-width: rem * 0.55;
                    anti-alias: true;
                }

                // Main pass
                Path {
                    width: parent.width;
                    height: parent.height;
                    viewbox-x: 0;
                    viewbox-y: 0;
                    viewbox-width: 100;
                    viewbox-height: 100;
                    commands: wave-path;
                    stroke: resonant-color;
                    stroke-width: rem * 0.18;
                    anti-alias: true;
                }

                Text {
                    x: rem * 0.75;
                    y: rem * 0.55;
                    text: "WgpuShaderZone (BSS)";
                    color: Colors.primary;
                    font-size: rem * 0.8;
                    font-weight: 600;
                }

                Text {
                    text: "Folded Resonance";
                    color: resonant-color;
                    font-size: rem * 0.8;
                    font-family: "monospace";
                    x: parent.width - self.width - rem * 0.75;
                    y: rem * 0.55;
                }

                Text {
                    text: "Time (10ms)";
                    color: Colors.on-surface-variant;
                    font-size: rem * 0.7;
                    font-family: "monospace";
                    x: (parent.width - self.width) / 2;
                    y: parent.height - self.height - rem * 0.5;
                }
            }

            // ═══════════════════════════════════════════════════════════════
            // TELEMETRY STRIP
            // ═══════════════════════════════════════════════════════════════
            HorizontalLayout {
                spacing: rem * 0.375;
                height: rem * 2.75;

                Rectangle {
                    width: rem * 8.5;
                    height: parent.height;
                    background: Colors.canvas-background;
                    border-radius: rem * 0.375;
                    border-width: rem * 0.06;
                    border-color: Colors.outline;

                    VerticalLayout {
                        padding: rem * 0.5;
                        spacing: rem * 0.25;

                        HorizontalLayout {
                            spacing: rem * 0.35;
                            alignment: center;

                            Rectangle {
                                width: rem * 0.4;
                                height: rem * 0.4;
                                border-radius: self.width / 2;
                                background: dvr-recording ? Colors.error : Colors.outline;
                            }

                            Text {
                                text: "DVR: " + (dvr-recording ? "REC" : "IDLE");
                                color: dvr-recording ? Colors.error : Colors.on-surface-variant;
                                font-size: rem * 0.75;
                                font-family: "monospace";
                                font-weight: 600;
                            }
                        }

                        Text {
                            text: "Buffer: " + dvr-buffer-days + " Days";
                            color: Colors.on-surface-variant;
                            font-size: rem * 0.65;
                            font-family: "monospace";
                        }
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                    height: parent.height;
                    background: Colors.canvas-background;
                    border-radius: rem * 0.375;
                    border-width: rem * 0.06;
                    border-color: Colors.outline;
                    clip: true;

                    VerticalLayout {
                        padding: rem * 0.5;
                        spacing: rem * 0.25;

                        HorizontalLayout {
                            Text {
                                text: "Learning Loss";
                                color: Colors.primary;
                                font-size: rem * 0.75;
                                font-weight: 600;
                            }

                            Rectangle { horizontal-stretch: 1; background: transparent; }

                            Text {
                                text: round(learning-loss * 1000) / 1000;
                                color: Colors.on-surface-variant;
                                font-size: rem * 0.75;
                                font-family: "monospace";
                                font-weight: 600;
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                            background: Colors.surface-container-low;
                            border-radius: rem * 0.25;
                            clip: true;

                            Path {
                                width: parent.width;
                                height: parent.height;
                                viewbox-x: 0;
                                viewbox-y: 0;
                                viewbox-width: 100;
                                viewbox-height: 100;
                                commands: loss-path;
                                stroke: Colors.primary;
                                stroke-width: rem * 0.12;
                                anti-alias: true;
                            }
                        }
                    }
                }

                // FieldPipeline Projections (Track A-1)
                Rectangle {
                    width: rem * 12.0;
                    height: parent.height;
                    background: Colors.canvas-background;
                    border-radius: rem * 0.375;
                    border-width: rem * 0.06;
                    border-color: Colors.outline;

                    VerticalLayout {
                        padding: rem * 0.5;
                        spacing: rem * 0.25;

                        Text {
                            text: "Field Projections";
                            color: Colors.tertiary;
                            font-size: rem * 0.75;
                            font-weight: 600;
                        }

                        // Drive
                        VerticalLayout {
                            spacing: rem * 0.125;

                            HorizontalLayout {
                                Text {
                                    text: "Drive";
                                    color: Colors.on-surface-variant;
                                    font-size: rem * 0.65;
                                    font-family: "monospace";
                                }

                                Rectangle { horizontal-stretch: 1; background: transparent; }

                                Text {
                                    text: round(drive * 1000) / 1000;
                                    color: Colors.on-surface-variant;
                                    font-size: rem * 0.65;
                                    font-family: "monospace";
                                }
                            }

                            Rectangle {
                                height: rem * 0.375;
                                background: Colors.surface-container-low;
                                border-radius: rem * 0.125;

                                Rectangle {
                                    width: parent.width * drive;
                                    height: parent.height;
                                    background: Colors.tertiary;
                                    border-radius: rem * 0.125;
                                }
                            }
                        }

                        // Fold
                        VerticalLayout {
                            spacing: rem * 0.125;

                            HorizontalLayout {
                                Text {
                                    text: "Fold";
                                    color: Colors.on-surface-variant;
                                    font-size: rem * 0.65;
                                    font-family: "monospace";
                                }

                                Rectangle { horizontal-stretch: 1; background: transparent; }

                                Text {
                                    text: round(fold * 1000) / 1000;
                                    color: Colors.on-surface-variant;
                                    font-size: rem * 0.65;
                                    font-family: "monospace";
                                }
                            }

                            Rectangle {
                                height: rem * 0.375;
                                background: Colors.surface-container-low;
                                border-radius: rem * 0.125;

                                Rectangle {
                                    width: parent.width * fold;
                                    height: parent.height;
                                    background: Colors.secondary;
                                    border-radius: rem * 0.125;
                                }
                            }
                        }

                        // Asym
                        VerticalLayout {
                            spacing: rem * 0.125;

                            HorizontalLayout {
                                Text {
                                    text: "Asym";
                                    color: Colors.on-surface-variant;
                                    font-size: rem * 0.65;
                                    font-family: "monospace";
                                }

                                Rectangle { horizontal-stretch: 1; background: transparent; }

                                Text {
                                    text: round(asym * 1000) / 1000;
                                    color: Colors.on-surface-variant;
                                    font-size: rem * 0.65;
                                    font-family: "monospace";
                                }
                            }

                            Rectangle {
                                height: rem * 0.375;
                                background: Colors.surface-container-low;
                                border-radius: rem * 0.125;

                                Rectangle {
                                    width: parent.width * asym;
                                    height: parent.height;
                                    background: Colors.primary;
                                    border-radius: rem * 0.125;
                                }
                            }
                        }
                    }
                }
                Rectangle {
                    width: rem * 3.0;
                    height: parent.height;
                    background: expanded ? Colors.surface-container : Colors.canvas-background;
                    border-radius: rem * 0.375;
                    border-width: rem * 0.06;
                    border-color: Colors.outline;

                    Text {
                        text: "⚙";
                        color: expanded ? Colors.on-surface : Colors.on-surface-variant;
                        font-size: rem * 1.125;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        clicked => { root.expanded = !root.expanded; }
                    }
                }
            }

            // ═══════════════════════════════════════════════════════════════
            // SETTINGS PANE (EXPANDABLE)
            // ═══════════════════════════════════════════════════════════════
            if expanded: Rectangle {
                background: Colors.canvas-background;
                border-radius: rem * 0.375;
                border-width: rem * 0.06;
                border-color: Colors.outline;

                VerticalLayout {
                    padding: rem * 0.75;
                    spacing: rem * 0.375;

                    HorizontalLayout {
                        spacing: rem * 0.375;
                        alignment: center;

                        Text {
                            text: "⚡";
                            color: Colors.secondary;
                            font-size: rem * 0.875;
                        }
                        Text {
                            text: "Active Denial";
                            color: Colors.on-surface;
                            font-size: rem * 0.8;
                            font-weight: 600;
                        }
                    }

                    VerticalLayout {
                        spacing: rem * 0.375;
                        DenialItem { rem: root.rem; label: "2.4GHz WiFi Jam"; freq: "2450 MHz"; active: true; }
                        DenialItem { rem: root.rem; label: "Bluetooth BLE Disruption"; freq: "2402 MHz"; active: false; }
                        DenialItem { rem: root.rem; label: "UHF Drone Link"; freq: "433 MHz"; active: false; }
                    }

                    HorizontalLayout {
                        spacing: rem * 0.375;
                        ChipButton { rem: root.rem; icon: "∿"; label: "Analyze"; }
                        ChipButton { rem: root.rem; icon: "⌁"; label: "Sweep"; }
                        ChipButton { rem: root.rem; icon: "⇩"; label: "Export"; }
                    }
                }

                animate opacity { duration: 300ms; }
            }
        }
    }
}
