// ui/applets/toto_hud.slint
// Toto HUD Applet — Compact Floating Instrument Widget (Slint)
//
// Design source: assets/prototyping/Compact_Floating_Instrument_Widget (React prototype)
// Overrides:
// - Dynamic wave stroke + frequency labels bind ONLY to `resonant-color` (Emerald City octave-fold).
// - Active Denial is autonomous in this widget variation: a single on/off toggle.
// - The fold-out bottom drawer focuses on training telemetry + recording; deeper configuration lands in future tabs.

import { Colors, Spacing, Typography, Fonts } from "../tokens.slint";

component Panel inherits Rectangle {
    in property <length> rem;
    in property <color> border-accent: Colors.outline;

    background: Colors.canvas-background;
    border-radius: rem * 0.375;
    border-width: rem * 0.06;
    border-color: border-accent;
}

component Divider inherits Rectangle {
    in property <length> rem;
    in property <length> divider-height: rem * 1.0;

    width: rem * 0.06;
    height: divider-height;
    background: Colors.outline-variant;
}

component ToggleSwitch inherits Rectangle {
    in property <length> rem;
    in-out property <bool> checked;
    callback toggled(bool);

    property <length> h: rem * 0.875;
    property <length> w: rem * 1.75;
    property <length> pad: rem * 0.10;

    width: w;
    height: h;
    border-radius: h / 2;
    border-width: rem * 0.06;
    border-color: checked ? Colors.primary : Colors.outline;
    background: checked ? Colors.primary.with-alpha(0.25) : Colors.surface-container-low;

    Rectangle {
        width: h - pad * 2;
        height: h - pad * 2;
        border-radius: self.height / 2;
        x: checked ? parent.width - self.width - pad : pad;
        y: pad;
        background: checked ? Colors.primary : Colors.on-surface-variant;

        animate x { duration: 160ms; easing: ease-in-out; }
        animate background { duration: 160ms; easing: ease-in-out; }
    }

    animate background { duration: 160ms; easing: ease-in-out; }
    animate border-color { duration: 160ms; easing: ease-in-out; }

    TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }
}

component ActionChip inherits Rectangle {
    in property <length> rem;
    in property <string> label;
    in property <string> icon;
    callback clicked;

    height: rem * 2.25;
    border-radius: rem * 0.375;
    background: Colors.canvas-background;
    border-color: Colors.outline;
    border-width: rem * 0.06;

    states [
        hover when touch.has-hover: { background: Colors.surface-container-low; }
        pressed when touch.pressed: { background: Colors.surface-container; }
    ]
    animate background { duration: 120ms; }

    HorizontalLayout {
        padding: rem * 0.375;
        spacing: rem * 0.30;
        alignment: center;

        Text {
            text: icon;
            color: Colors.on-surface-variant;
            font-size: rem * 0.70;
            font-family: Fonts.mono;
            vertical-alignment: center;
        }

        Text {
            text: label;
            color: Colors.on-surface-variant;
            font-size: rem * 0.70;
            font-weight: 500;
            font-family: Fonts.primary;
            vertical-alignment: center;
        }
    }

    touch := TouchArea { clicked => root.clicked(); }
}

export component TotoHudApplet inherits Window {
    title: "Toto HUD";
    no-frame: true;
    background: transparent;

    // Public properties (wired from Rust)
    in-out property <length> unit-size: 384px;
    in-out property <bool> expanded: false;

    in-out property <float> anomaly-score: 0.0;
    in-out property <bool> auto-steer: true;

    in-out property <float> dominant-freq-hz: 0.0;
    in-out property <string> wave-path: "M 0 50 L 100 50";

    in-out property <float> learning-loss: 0.0;
    in-out property <string> loss-path: "M 0 100 L 100 100";

    in-out property <bool> dvr-recording: false;
    in-out property <int> dvr-buffer-days: 0;

    in-out property <float> drive: 0.0;
    in-out property <float> fold: 0.0;
    in-out property <float> asym: 0.0;

    in-out property <float> animation-tick: 0.0;

    // Dynamic data color (Emerald City octave-fold mapping)
    in-out property <color> resonant-color: Colors.harm-0;

    // Active Denial (autonomous widget toggle)
    in-out property <bool> active-denial-enabled: false;

    // Events (optional for Rust wiring)
    callback request-export-dvr();
    callback request-snapshot();
    callback request-toggle-training(bool);

    // Single scaling knob (all lengths derived)
    property <length> rem: unit-size / 24;

    // Bind global tokens to this applet's unit-size.
    width: unit-size;
    height: unit-size / 1.6 + (expanded ? (rem * 9.0 + rem * 0.375) : 0);

    Panel {
        rem: root.rem;
        border-accent: Colors.outline;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;

        // Root fill: slightly translucent so compositor blur reads.
        background: Colors.surface-dim.with-alpha(0.88);

        VerticalLayout {
            padding: rem * 0.50;
            spacing: rem * 0.375;

            // ═══════════════════════════════════════════════════════════════
            // HEADER
            // ═══════════════════════════════════════════════════════════════
            Panel {
                rem: root.rem;
                height: rem * 2.5;
                background: Colors.surface-container-low;

                HorizontalLayout {
                    padding: rem * 0.75;
                    spacing: rem * 0.60;
                    alignment: center;

                    HorizontalLayout {
                        spacing: rem * 0.60;
                        alignment: center;

                        Text {
                            text: "TOTO CORE";
                            color: Colors.primary;
                            font-family: Fonts.primary;
                            font-size: rem * 0.78;
                            font-weight: 700;
                            letter-spacing: rem * 0.10;
                            vertical-alignment: center;
                        }

                        Divider { rem: root.rem; divider-height: rem * 1.1; }

                        HorizontalLayout {
                            spacing: rem * 0.25;
                            alignment: center;

                            Text {
                                text: "Anomaly Score";
                                color: Colors.on-surface-variant;
                                font-family: Fonts.primary;
                                font-size: rem * 0.70;
                                font-weight: 500;
                                vertical-alignment: center;
                            }

                            Text {
                                text: round(anomaly-score * 1000) / 1000;
                                color: Colors.secondary;
                                font-family: Fonts.mono;
                                font-size: rem * 0.78;
                                font-weight: 700;
                                vertical-alignment: center;

                                animate color { duration: 300ms; easing: ease-in-out; }
                            }
                        }
                    }

                    Rectangle { horizontal-stretch: 1; background: transparent; }

                    HorizontalLayout {
                        spacing: rem * 0.50;
                        alignment: center;

                        Text {
                            text: "Neural Auto-Steer";
                            color: Colors.primary.with-alpha(0.85);
                            font-family: Fonts.primary;
                            font-size: rem * 0.70;
                            font-weight: 500;
                            vertical-alignment: center;
                        }

                        ToggleSwitch {
                            rem: root.rem;
                            checked <=> root.auto-steer;
                        }
                    }
                }
            }

            // ═══════════════════════════════════════════════════════════════
            // OSCILLOSCOPE CANVAS
            // ═══════════════════════════════════════════════════════════════
            Panel {
                rem: root.rem;
                background: Colors.surface-container-low;
                height: rem * 5.0;
                vertical-stretch: 1;

                Rectangle {
                    x: rem * 0.75;
                    y: rem * 0.75;
                    width: parent.width - rem * 1.5;
                    height: parent.height - rem * 1.5;
                    background: transparent;

                    // Labels
                    Text {
                        text: "WgpuShaderZone (BSS)";
                        x: 0;
                        y: 0;
                        color: resonant-color;
                        font-family: Fonts.primary;
                        font-size: rem * 0.70;
                        font-weight: 500;

                        animate color { duration: 320ms; easing: ease-in-out; }
                    }

                    Text {
                        text: round(dominant-freq-hz / 1000) + " kHz";
                        x: parent.width - self.width;
                        y: 0;
                        color: resonant-color;
                        font-family: Fonts.mono;
                        font-size: rem * 0.70;
                        font-weight: 700;

                        animate color { duration: 320ms; easing: ease-in-out; }
                    }

                    // Grid
                    Rectangle {
                        x: 0;
                        y: rem * 1.5;
                        width: parent.width;
                        height: parent.height - rem * 2.0;
                        background: transparent;

                        // Vertical grid lines
                        for i in 10 : Rectangle {
                            x: parent.width * i / 9;
                            y: 0;
                            width: rem * 0.03;
                            height: parent.height;
                            background: Colors.outline-variant;
                        }

                        // Horizontal grid lines
                        for j in 5 : Rectangle {
                            x: 0;
                            y: parent.height * j / 4;
                            width: parent.width;
                            height: rem * 0.03;
                            background: Colors.outline-variant;
                        }
                    }

                    // Wave path (glow + main pass)
                    Rectangle {
                        x: 0;
                        y: rem * 1.5;
                        width: parent.width;
                        height: parent.height - rem * 2.0;
                        background: transparent;

                        Path {
                            width: parent.width;
                            height: parent.height;
                            viewbox-x: 0;
                            viewbox-y: 0;
                            viewbox-width: 100;
                            viewbox-height: 100;
                            commands: wave-path;
                            stroke: resonant-color.with-alpha(0.28);
                            stroke-width: rem * 0.55;
                            anti-alias: true;
                        }

                        Path {
                            width: parent.width;
                            height: parent.height;
                            viewbox-x: 0;
                            viewbox-y: 0;
                            viewbox-width: 100;
                            viewbox-height: 100;
                            commands: wave-path;
                            stroke: resonant-color;
                            stroke-width: rem * 0.16;
                            anti-alias: true;

                            animate stroke { duration: 320ms; easing: ease-in-out; }
                        }
                    }

                    Text {
                        text: "Time (10ms)";
                        x: parent.width / 2 - self.width / 2;
                        y: parent.height - self.height;
                        color: Colors.primary.with-alpha(0.7);
                        font-family: Fonts.mono;
                        font-size: rem * 0.70;
                    }
                }
            }

            // ═══════════════════════════════════════════════════════════════
            // TELEMETRY STRIP
            // ═══════════════════════════════════════════════════════════════
            HorizontalLayout {
                spacing: rem * 0.375;

                Panel {
                    rem: root.rem;
                    background: Colors.surface-container-low;
                    horizontal-stretch: 1;
                    height: rem * 2.75;

                    HorizontalLayout {
                        padding: rem * 0.60;
                        spacing: rem * 0.50;
                        alignment: center;

                        // DVR block
                        VerticalLayout {
                            spacing: rem * 0.10;

                            HorizontalLayout {
                                spacing: rem * 0.30;
                                alignment: center;

                                Rectangle {
                                    width: rem * 0.40;
                                    height: rem * 0.40;
                                    border-radius: rem * 0.20;
                                    background: dvr-recording ? Colors.error : Colors.outline-variant;
                                }

                                Text {
                                    text: dvr-recording ? "DVR: REC" : "DVR: IDLE";
                                    color: Colors.on-surface;
                                    font-family: Fonts.primary;
                                    font-size: rem * 0.70;
                                    font-weight: 600;
                                }
                            }

                            Text {
                                text: "Buffer: " + dvr-buffer-days + " Days";
                                color: Colors.on-surface-variant;
                                font-family: Fonts.mono;
                                font-size: rem * 0.60;
                            }
                        }

                        Divider { rem: root.rem; divider-height: rem * 1.8; }

                        // Loss sparkline
                        VerticalLayout {
                            spacing: rem * 0.10;
                            horizontal-stretch: 1;

                            HorizontalLayout {
                                Text {
                                    text: "Learning Loss";
                                    color: Colors.primary;
                                    font-family: Fonts.primary;
                                    font-size: rem * 0.60;
                                    font-weight: 600;
                                }

                                Rectangle { horizontal-stretch: 1; background: transparent; }

                                Text {
                                    text: round(learning-loss * 1000) / 1000;
                                    color: Colors.on-surface;
                                    font-family: Fonts.mono;
                                    font-size: rem * 0.60;
                                    font-weight: 700;
                                }
                            }

                            Rectangle {
                                height: rem * 1.05;
                                background: Colors.surface-container;
                                border-radius: rem * 0.25;
                                border-width: rem * 0.06;
                                border-color: Colors.outline-variant;

                                Path {
                                    width: parent.width;
                                    height: parent.height;
                                    viewbox-x: 0;
                                    viewbox-y: 0;
                                    viewbox-width: 100;
                                    viewbox-height: 100;
                                    commands: loss-path;
                                    stroke: Colors.primary;
                                    stroke-width: rem * 0.10;
                                    anti-alias: true;
                                }
                            }
                        }
                    }
                }

                // Gear / expand control
                Panel {
                    rem: root.rem;
                    width: rem * 3.0;
                    height: rem * 2.75;
                    background: expanded ? Colors.surface-container : Colors.surface-container-low;

                    Text {
                        text: "⚙";
                        color: expanded ? Colors.on-surface : Colors.on-surface-variant;
                        font-family: Fonts.mono;
                        font-size: rem * 1.10;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea { clicked => { root.expanded = !root.expanded; } }
                }
            }

            // ═══════════════════════════════════════════════════════════════
            // BOTTOM DRAWER (Fold-out)
            // ═══════════════════════════════════════════════════════════════
            Panel {
                rem: root.rem;
                background: Colors.surface-container-low;
                border-accent: Colors.outline;
                height: expanded ? rem * 9.0 : 0;
                opacity: expanded ? 1 : 0;
                clip: true;

                animate height { duration: 280ms; easing: ease-in-out; }
                animate opacity { duration: 200ms; easing: ease-in-out; }

                VerticalLayout {
                    padding: rem * 0.75;
                    spacing: rem * 0.60;

                    // Toggles row
                    HorizontalLayout {
                        spacing: rem * 0.75;
                        alignment: center;

                        HorizontalLayout {
                            spacing: rem * 0.40;
                            alignment: center;

                            Text {
                                text: "Active Denial";
                                color: Colors.on-surface;
                                font-family: Fonts.primary;
                                font-size: rem * 0.70;
                                font-weight: 600;
                            }

                            ToggleSwitch {
                                rem: root.rem;
                                checked <=> root.active-denial-enabled;
                            }
                        }

                        Rectangle { horizontal-stretch: 1; background: transparent; }

                        HorizontalLayout {
                            spacing: rem * 0.40;
                            alignment: center;

                            Text {
                                text: "Rolling Record";
                                color: Colors.on-surface;
                                font-family: Fonts.primary;
                                font-size: rem * 0.70;
                                font-weight: 600;
                            }

                            ToggleSwitch {
                                rem: root.rem;
                                checked <=> root.dvr-recording;
                            }
                        }
                    }

                    // Training telemetry
                    Panel {
                        rem: root.rem;
                        background: Colors.surface-container;
                        border-accent: Colors.outline-variant;
                        height: rem * 4.2;

                        VerticalLayout {
                            padding: rem * 0.60;
                            spacing: rem * 0.35;

                            HorizontalLayout {
                                Text {
                                    text: "Training Telemetry";
                                    color: Colors.primary;
                                    font-family: Fonts.primary;
                                    font-size: rem * 0.70;
                                    font-weight: 700;
                                }

                                Rectangle { horizontal-stretch: 1; background: transparent; }

                                Text {
                                    text: round(learning-loss * 1000) / 1000;
                                    color: Colors.on-surface;
                                    font-family: Fonts.mono;
                                    font-size: rem * 0.70;
                                    font-weight: 700;
                                }
                            }

                            Rectangle {
                                height: rem * 2.2;
                                background: Colors.surface-dim;
                                border-radius: rem * 0.25;
                                border-width: rem * 0.06;
                                border-color: Colors.outline-variant;

                                Path {
                                    width: parent.width;
                                    height: parent.height;
                                    viewbox-x: 0;
                                    viewbox-y: 0;
                                    viewbox-width: 100;
                                    viewbox-height: 100;
                                    commands: loss-path;
                                    stroke: Colors.primary;
                                    stroke-width: rem * 0.12;
                                    anti-alias: true;
                                }
                            }

                            // Projections (Drive/Fold/Asym)
                            HorizontalLayout {
                                spacing: rem * 0.60;

                                // Drive
                                VerticalLayout {
                                    spacing: rem * 0.10;
                                    horizontal-stretch: 1;

                                    HorizontalLayout {
                                        Text { text: "Drive"; color: Colors.on-surface-variant; font-family: Fonts.mono; font-size: rem * 0.60; }
                                        Rectangle { horizontal-stretch: 1; background: transparent; }
                                        Text { text: round(drive * 1000) / 1000; color: Colors.on-surface-variant; font-family: Fonts.mono; font-size: rem * 0.60; }
                                    }

                                    Rectangle {
                                        height: rem * 0.30;
                                        background: Colors.surface-container-high;
                                        border-radius: rem * 0.12;
                                        Rectangle { width: parent.width * drive; height: parent.height; background: Colors.primary; border-radius: rem * 0.12; }
                                    }
                                }

                                // Fold
                                VerticalLayout {
                                    spacing: rem * 0.10;
                                    horizontal-stretch: 1;

                                    HorizontalLayout {
                                        Text { text: "Fold"; color: Colors.on-surface-variant; font-family: Fonts.mono; font-size: rem * 0.60; }
                                        Rectangle { horizontal-stretch: 1; background: transparent; }
                                        Text { text: round(fold * 1000) / 1000; color: Colors.on-surface-variant; font-family: Fonts.mono; font-size: rem * 0.60; }
                                    }

                                    Rectangle {
                                        height: rem * 0.30;
                                        background: Colors.surface-container-high;
                                        border-radius: rem * 0.12;
                                        Rectangle { width: parent.width * fold; height: parent.height; background: Colors.secondary; border-radius: rem * 0.12; }
                                    }
                                }

                                // Asym
                                VerticalLayout {
                                    spacing: rem * 0.10;
                                    horizontal-stretch: 1;

                                    HorizontalLayout {
                                        Text { text: "Asym"; color: Colors.on-surface-variant; font-family: Fonts.mono; font-size: rem * 0.60; }
                                        Rectangle { horizontal-stretch: 1; background: transparent; }
                                        Text { text: round(asym * 1000) / 1000; color: Colors.on-surface-variant; font-family: Fonts.mono; font-size: rem * 0.60; }
                                    }

                                    Rectangle {
                                        height: rem * 0.30;
                                        background: Colors.surface-container-high;
                                        border-radius: rem * 0.12;
                                        Rectangle { width: parent.width * asym; height: parent.height; background: Colors.primary; border-radius: rem * 0.12; }
                                    }
                                }
                            }
                        }
                    }

                    // Actions
                    HorizontalLayout {
                        spacing: rem * 0.375;
                        ActionChip { rem: root.rem; icon: "⇩"; label: "Export DVR"; clicked => root.request-export-dvr(); }
                        ActionChip { rem: root.rem; icon: "⧉"; label: "Snapshot"; clicked => root.request-snapshot(); }
                    }
                }
            }
        }
    }
}
