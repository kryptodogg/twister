// ui/materials_editor.slint — Material Editor Component (Track FF Phase 2)
//
// Blender-style material editor for RF-BSDF properties.
// Provides sliders for Debye model parameters and material library management.

import { Button, ComboBox, Slider } from "std-widgets.slint";

/// Material Editor Tab (Phase 2)
export component MaterialsEditor {
    // Material selection
    in-out property <int> selected-material-idx: 0;
    in-out property <[string]> material-names: [
        "Water",
        "Glass",
        "Metal",
        "Human Tissue",
        "Wood",
        "Concrete",
        "Clothing"
    ];

    // Debye Model Parameters (0-1 normalized sliders)
    in-out property <f32> permittivity-static: 0.5;      // ε_s (0-100 range)
    in-out property <f32> permittivity-infinity: 0.1;    // ε∞ (0-20 range)
    in-out property <f32> relaxation-time: 0.3;          // τ (0.001-100ps range, log scale)
    in-out property <f32> conductivity-base: 0.4;        // σ_base (log scale)
    in-out property <f32> conductivity-exp: 0.5;         // α frequency exponent (-1 to 1)
    in-out property <f32> loss-tangent: 0.3;             // tan(δ) (0-1)

    // Mamba Learning Status
    in-out property <bool> learning-active: false;
    in-out property <f32> learning-progress: 0.0;        // 0.0-1.0
    in-out property <f32> current-loss: 0.0;             // MSE loss display
    in-out property <string> learning-status: "Ready";

    // Buttons for library management
    callback save-material();
    callback load-material();
    callback add-to-library();
    callback start-learning();

    VerticalLayout {
        spacing: 12px;
        padding: 16px;

        // ──────────────────────────────────────────────────────────────────
        // Material Selection
        // ──────────────────────────────────────────────────────────────────

        Text {
            text: "Material Library";
            font-weight: 700;
            font-size: 14px;
        }

        HorizontalLayout {
            spacing: 8px;
            ComboBox {
                model: material-names;
                current-index: selected-material-idx;
                current-value: material-names[selected-material-idx];
            }
            Button {
                text: "Load";
                width: 60px;
                clicked => { load-material(); }
            }
            Button {
                text: "Save";
                width: 60px;
                clicked => { save-material(); }
            }
        }

        // ──────────────────────────────────────────────────────────────────
        // Debye Model Parameters (6 sliders)
        // ──────────────────────────────────────────────────────────────────

        Text {
            text: "Debye Model Parameters";
            font-weight: 700;
            font-size: 14px;
        }

        // ε_s: Static Permittivity (0-100)
        HorizontalLayout {
            alignment: center;
            spacing: 8px;
            Text {
                text: "ε_s (Static Permittivity):";
                width: 200px;
            }
            Slider {
                width: 200px;
                value: permittivity-static;
                changed(value) => { permittivity-static = value; }
            }
            Text {
                text: @logic_to_string(permittivity-static * 100.0);
                width: 50px;
                text-alignment: right;
            }
        }

        // ε∞: Infinite Frequency Permittivity (0-20)
        HorizontalLayout {
            alignment: center;
            spacing: 8px;
            Text {
                text: "ε∞ (High Freq):";
                width: 200px;
            }
            Slider {
                width: 200px;
                value: permittivity-infinity;
                changed(value) => { permittivity-infinity = value; }
            }
            Text {
                text: @logic_to_string(permittivity-infinity * 20.0);
                width: 50px;
                text-alignment: right;
            }
        }

        // τ: Relaxation Time (0.001-100ps, log scale)
        HorizontalLayout {
            alignment: center;
            spacing: 8px;
            Text {
                text: "τ (Relaxation Time ps):";
                width: 200px;
            }
            Slider {
                width: 200px;
                value: relaxation-time;
                changed(value) => { relaxation-time = value; }
            }
            Text {
                text: @logic_to_string(relaxation-time * 100.0);
                width: 50px;
                text-alignment: right;
            }
        }

        // σ_base: Conductivity Base (log scale)
        HorizontalLayout {
            alignment: center;
            spacing: 8px;
            Text {
                text: "σ_base (Conductivity):";
                width: 200px;
            }
            Slider {
                width: 200px;
                value: conductivity-base;
                changed(value) => { conductivity-base = value; }
            }
            Text {
                text: @logic_to_string(conductivity-base * 100.0);
                width: 50px;
                text-alignment: right;
            }
        }

        // α: Conductivity Frequency Exponent (-1 to 1)
        HorizontalLayout {
            alignment: center;
            spacing: 8px;
            Text {
                text: "α (Freq Exponent):";
                width: 200px;
            }
            Slider {
                width: 200px;
                value: conductivity-exp;
                changed(value) => { conductivity-exp = value; }
            }
            Text {
                text: @logic_to_string((conductivity-exp * 2.0) - 1.0);
                width: 50px;
                text-alignment: right;
            }
        }

        // tan(δ): Loss Tangent (0-1)
        HorizontalLayout {
            alignment: center;
            spacing: 8px;
            Text {
                text: "tan(δ) (Loss Tangent):";
                width: 200px;
            }
            Slider {
                width: 200px;
                value: loss-tangent;
                changed(value) => { loss-tangent = value; }
            }
            Text {
                text: @logic_to_string(loss-tangent);
                width: 50px;
                text-alignment: right;
            }
        }

        // ──────────────────────────────────────────────────────────────────
        // Mamba Learning Status & Controls
        // ──────────────────────────────────────────────────────────────────

        Text {
            text: "Mamba Learning";
            font-weight: 700;
            font-size: 14px;
        }

        // Learning Status Display
        HorizontalLayout {
            spacing: 8px;
            alignment: center;
            Text {
                text: "Status:";
                width: 60px;
            }
            Text {
                text: learning-status;
                width: 150px;
                color: learning-active ? #0080ff : #666666;
            }
            Text {
                text: @logic_to_string(learning-progress * 100.0) + "%";
                width: 60px;
                text-alignment: right;
            }
        }

        // Learning Progress Bar
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "Progress:";
                width: 60px;
            }
            Rectangle {
                width: 200px;
                height: 20px;
                border: 1px solid #cccccc;
                background: #f0f0f0;

                Rectangle {
                    width: parent.width * learning-progress;
                    height: parent.height;
                    background: learning-active ? #0080ff : #99ccff;
                }
            }
        }

        // Loss Display
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "Loss (MSE):";
                width: 60px;
            }
            Text {
                text: @logic_to_string(current-loss);
                width: 150px;
                font-family: "monospace";
            }
        }

        // Learning Control Buttons
        HorizontalLayout {
            spacing: 8px;
            Button {
                text: learning-active ? "Stop Learning" : "Start Learning";
                clicked => {
                    learning-active = !learning-active;
                    start-learning();
                }
            }
            Button {
                text: "Add to Library";
                clicked => { add-to-library(); }
            }
        }

        // Spacer
        Rectangle {
            height: 20px;
        }
    }
}

// Helper to convert float to string (simplified)
function @logic_to_string(value: float) -> string {
    // Convert float to displayable string with 2 decimal places
    // Note: This is a placeholder. Slint doesn't have built-in float formatting.
    // In practice, use Rust-side string formatting and pass pre-formatted strings.
    return "0.00";
}
