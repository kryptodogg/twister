{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "synesthesia",
  "version": "0.1.0",
  "identifier": "com.pixel.synesthesia",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "brick-road",
        "title": "Brick Road \u2014 Settings",
        "transparent": true,
        "decorations": false,
        "visible": false,
        "width": 1100,
        "height": 780,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}